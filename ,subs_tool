# --- Core Helper Functions ---

def print_version():
    print(f",subs_tool - Version {VERSION}")
    print("-" * 30)

def format_timestamp(seconds):
    """Converts seconds (float) to SRT timestamp format."""
    if seconds is None: return "00:00:00,000"
    milliseconds = int((seconds - int(seconds)) * 1000)
    minutes, seconds = divmod(int(seconds), 60)
    hours, minutes = divmod(minutes, 60)
    return f"{hours:02d}:{minutes:02d}:{seconds:02d},{milliseconds:03d}"

def get_stream_info(file_path):
    cmd = ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_streams", file_path]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return json.loads(result.stdout).get('streams', [])
    except Exception:
        return []

def format_subtitle_label(stream):
    idx = stream.get('index')
    codec_raw = stream.get('codec_name', 'unknown')
    codec_friendly = SUBTITLE_CODEC_MAP.get(codec_raw, codec_raw)
    tags = stream.get('tags', {})
    lang_code = tags.get('language', 'und')
    lang_name = ISO_639_MAP.get(lang_code, lang_code)
    title = tags.get('title', '')
    title_str = f" - {title}" if title else ""
    return f"Stream #{idx}: {lang_name} [{lang_code}] [{codec_friendly}]{title_str}"

# --- OCR Pipeline ---

def extract_subtitle_packets(input_file, stream_index):
    cmd = [
        "ffprobe", "-v", "quiet", 
        "-select_streams", f"{stream_index}",
        "-show_entries", "packet=pts_time,duration_time",
        "-of", "json", input_file
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        packets = json.loads(result.stdout).get("packets", [])
        clean_packets = []
        for p in packets:
            if 'pts_time' in p:
                clean_packets.append({
                    'start': float(p['pts_time']),
                    'duration': float(p.get('duration_time', 0))
                })
        return clean_packets
    except Exception:
        return []

def extract_single_image(input_file, stream_index, timestamp, output_path):
    seek_time = max(0, timestamp + 0.1)
    cmd = [
        "ffmpeg", "-nostdin", "-hide_banner", "-loglevel", "error",
        "-ss", f"{seek_time}", "-i", input_file,
        "-f", "lavfi", "-i", "color=size=1920x1080:color=black:rate=24",
        "-filter_complex", f"[1:v][0:{stream_index}]overlay",
        "-frames:v", "1", "-y", output_path
    ]
    try:
        subprocess.run(cmd, check=True)
        return True
    except subprocess.CalledProcessError:
        return False

def perform_manual_ocr(input_file, stream_index, lang_code, output_srt, temp_dir):
    """Orchestrates image extraction, Tesseract OCR, and SRT generation."""
    print(f"    ... Processing Stream #{stream_index} ({lang_code})...")
    
    stream_temp_dir = os.path.join(temp_dir, f"stream_{stream_index}")
    if os.path.exists(stream_temp_dir): shutil.rmtree(stream_temp_dir)
    os.makedirs(stream_temp_dir, exist_ok=True)

    # 1. Get Timestamps
    packets = extract_subtitle_packets(input_file, stream_index)
    if not packets:
        print("    -> No packets found.")
        return False

    # 2. Extract Images (Parallel)
    print(f"    -> Rendering {len(packets)} images (Multithreaded)...")
    with ThreadPoolExecutor(max_workers=4) as executor:
        for i, packet in enumerate(packets):
            img_name = os.path.join(stream_temp_dir, f"img_{i:05d}.tif")
            executor.submit(extract_single_image, input_file, stream_index, packet['start'], img_name)
    
    # 3. OCR Loop
    images = sorted(glob.glob(os.path.join(stream_temp_dir, "*.tif")))
    if not images: return False
    
    count = min(len(images), len(packets))
    print(f"    -> OCRing {count} lines...")
    
    srt_lines = []
    if lang_code == 'und': lang_code = 'eng'
    
    # Progress indicator
    for i in range(count):
        if count > 10 and i % (count // 10) == 0:
            sys.stdout.write(".")
            sys.stdout.flush()
            
        cmd_tess = ["tesseract", images[i], "stdout", "-l", lang_code, "--psm", "6"]
        try:
            result = subprocess.run(cmd_tess, capture_output=True, text=True)
            text = result.stdout.strip()
            if text:
                start = format_timestamp(packets[i]['start'])
                end = format_timestamp(packets[i]['start'] + max(packets[i]['duration'], 1.5))
                srt_lines.append(f"{i+1}\n{start} --> {end}\n{text}\n")
        except Exception: pass
    
    sys.stdout.write("\n")
    
    # 4. Write SRT
    if not srt_lines:
        print("    -> No text recognized.")
        return False
        
    with open(output_srt, 'w', encoding='utf-8') as f:
        f.write("\n".join(srt_lines))
    
    shutil.rmtree(stream_temp_dir)
    return True

# --- Main Processing Logic ---

def process_remux(input_path, output_path, state_map):
    """
    state_map: dict { stream_index: 'KEEP' | 'REMOVE' | 'CONVERT' }
    """
    # Ensure temp dir exists
    os.makedirs(TEMP_DIR, exist_ok=True)
    base_name = os.path.basename(output_path)
    temp_final = os.path.join(TEMP_DIR, f"TEMP_REMUX_{int(time.time())}_{base_name}")
    ocr_work_dir = os.path.join(TEMP_DIR, "OCR_WORK")
    os.makedirs(ocr_work_dir, exist_ok=True)

    all_streams = get_stream_info(input_path)
    generated_srts = []

    # 1. Handle Conversions first (Heavy lifting)
    convert_indices = [idx for idx, action in state_map.items() if action == 'CONVERT']
    
    if convert_indices:
        print("\n--- Starting Conversion Phase ---")
        if not shutil.which("tesseract"):
            print("Error: Tesseract not installed. Cannot convert.")
            return

        for idx in convert_indices:
            # Find stream details
            stream = next((s for s in all_streams if s['index'] == idx), None)
            if not stream: continue
            
            lang = stream.get('tags', {}).get('language', 'eng')
            title = stream.get('tags', {}).get('title', '')
            srt_path = os.path.join(ocr_work_dir, f"converted_{idx}.srt")
            
            if perform_manual_ocr(input_path, idx, lang, srt_path, ocr_work_dir):
                generated_srts.append({
                    'path': srt_path,
                    'lang': lang,
                    'title': f"{title} (OCR)" if title else "OCR"
                })
            else:
                print(f"Warning: Failed to convert stream #{idx}. It will be kept as original.")
                state_map[idx] = 'KEEP' # Fallback

    # 2. Build FFmpeg Command
    print("\n--- Building Final File ---")
    cmd = ["ffmpeg", "-hide_banner", "-v", "error", "-stats", "-i", input_path]
    
    # Add new SRT inputs
    for srt in generated_srts:
        cmd.extend(["-i", srt['path']])

    # Map Video (All)
    for s in all_streams:
        if s.get('codec_type') == 'video':
            cmd.extend(["-map", f"0:{s['index']}"])
    
    # Map Audio (All)
    for s in all_streams:
        if s.get('codec_type') == 'audio':
            cmd.extend(["-map", f"0:{s['index']}"])
            
    # Map Subtitles
    # 1. Existing Subs (that are marked KEEP or failed conversion)
    #    Note: 'CONVERT' status implies we remove the original and map the new one?
    #    Usually yes. If user selected Convert, they want SRT *instead* of image.
    current_sub_count = 0
    
    for s in all_streams:
        if s.get('codec_type') == 'subtitle':
            idx = s['index']
            action = state_map.get(idx, 'KEEP')
            
            if action == 'KEEP':
                cmd.extend(["-map", f"0:{idx}"])
                current_sub_count += 1
            # If REMOVE or CONVERT, we do not map the original stream 0:idx
    
    # 2. New SRTs
    # Input 0 is video. Inputs 1..N are SRTs
    for i, srt in enumerate(generated_srts):
        input_idx = i + 1
        cmd.extend(["-map", f"{input_idx}:s"])
        
        # Metadata
        out_idx = current_sub_count + i
        cmd.extend([
            f"-metadata:s:s:{out_idx}", f"language={srt['lang']}",
            f"-metadata:s:s:{out_idx}", f"title={srt['title']}"
        ])

    # Map Attachments/Data
    cmd.extend(["-map", "0:d?", "-map", "0:t?"])
    
    # Finalize
    cmd.extend(["-c", "copy", "-map_metadata", "0", "-y", temp_final])
    
    try:
        subprocess.run(cmd, check=True)
        if os.path.exists(temp_final) and os.path.getsize(temp_final) > 0:
            print(f"Moving to: {output_path}")
            shutil.move(temp_final, output_path)
            print("Success!")
        else:
            print("Error: Output empty.")
    except subprocess.CalledProcessError as e:
        print(f"FFmpeg Error: {e}")
    finally:
        if os.path.exists(ocr_work_dir): shutil.rmtree(ocr_work_dir)

# --- TUI Functions ---

def draw_menu(stdscr, filename, subtitles, state_map, output_path, cursor_pos, edit_mode=False):
    stdscr.clear()
    h, w = stdscr.getmaxyx()
    
    # Header
    header = f",subs_tool v{VERSION} - {filename}"
    stdscr.addstr(0, 0, header[:w-1], curses.A_BOLD | curses.A_UNDERLINE)
    
    instr = "[Space] Toggle | [A] Remove non-Eng | [C] Convert non-SRT | [R] Run | [Q] Quit"
    stdscr.addstr(1, 0, instr[:w-1], curses.A_DIM)
    stdscr.addstr(2, 0, "-" * (w-1))

    # List
    list_start_y = 3
    max_visible = h - 6
    scroll_offset = max(0, cursor_pos - max_visible + 1)
    
    for i in range(max_visible):
        idx_in_list = i + scroll_offset
        if idx_in_list >= len(subtitles): break
        
        sub = subtitles[idx_in_list]
        idx = sub['index']
        label = format_subtitle_label(sub)
        
        status = state_map.get(idx, 'KEEP')
        
        # Style Logic
        color = curses.color_pair(2) # Green KEEP default
        check = "[ ] KEEP   "
        
        if status == 'REMOVE':
            color = curses.color_pair(1) # Red
            check = "[*] REMOVE "
        elif status == 'CONVERT':
            color = curses.color_pair(3) # Cyan
            check = "[C] CONVERT"
            
        style = color
        if idx_in_list == cursor_pos and not edit_mode:
            style |= curses.A_REVERSE
            
        # Highlight non-SRT codecs in list if not selected?
        # Actually, let's just make the label bold if it's image based?
        # Simpler: just print the line.
        
        line = f" {check} {label}"
        stdscr.addstr(list_start_y + i, 0, line[:w-1], style)

    # Output
    out_y = h - 2
    lbl = "Output: "
    stdscr.addstr(out_y, 0, lbl, curses.A_BOLD)
    style_path = curses.A_REVERSE if edit_mode else curses.A_NORMAL
    disp_path = output_path
    avail = w - len(lbl) - 1
    if len(disp_path) > avail: disp_path = "..." + disp_path[-(avail-3):]
    stdscr.addstr(out_y, len(lbl), disp_path, style_path)
    
    stdscr.refresh()

def draw_confirmation_popup(stdscr, subtitles, state_map):
    """Draws a popup window over the main UI."""
    h, w = stdscr.getmaxyx()
    
    # Calculate stats
    to_remove = sum(1 for s in subtitles if state_map.get(s['index']) == 'REMOVE')
    to_convert = sum(1 for s in subtitles if state_map.get(s['index']) == 'CONVERT')
    to_keep = sum(1 for s in subtitles if state_map.get(s['index']) == 'KEEP')
    
    # Dimensions
    box_h, box_w = 10, 50
    start_y, start_x = (h - box_h) // 2, (w - box_w) // 2
    
    win = curses.newwin(box_h, box_w, start_y, start_x)
    win.box()
    
    win.addstr(1, 2, "CONFIRMATION SUMMARY", curses.A_BOLD | curses.A_UNDERLINE)
    win.addstr(3, 4, f"Removing:   {to_remove} tracks", curses.color_pair(1))
    win.addstr(4, 4, f"Converting: {to_convert} tracks", curses.color_pair(3))
    win.addstr(5, 4, f"Keeping:    {to_keep} tracks", curses.color_pair(2))
    
    win.addstr(7, 2, "Proceed with these changes? (Y/n)")
    win.refresh()
    
    while True:
        key = stdscr.getch()
        if key in (ord('y'), ord('Y'), 10, 13): # Yes or Enter
            return True
        if key in (ord('n'), ord('N'), 27): # No or Esc
            return False

def tui_main(stdscr, args):
    # Colors
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_RED, -1)    # Remove
    curses.init_pair(2, curses.COLOR_GREEN, -1)  # Keep
    curses.init_pair(3, curses.COLOR_CYAN, -1)   # Convert
    
    curses.curs_set(0)
    stdscr.timeout(100)
    
    input_path = os.path.abspath(args.input)
    filename = os.path.basename(input_path)
    output_path = input_path
    
    streams = get_stream_info(input_path)
    subtitles = [s for s in streams if s.get('codec_type') == 'subtitle']
    
    if not subtitles: return None
    
    # State Map: { index: 'KEEP' } (default)
    state_map = {s['index']: 'KEEP' for s in subtitles}
    cursor_pos = 0
    edit_mode = False
    
    while True:
        draw_menu(stdscr, filename, subtitles, state_map, output_path, cursor_pos, edit_mode)
        key = stdscr.getch()
        
        if edit_mode:
            if key in (10, 13, 27): # Enter/Esc
                edit_mode = False
                curses.curs_set(0)
            elif key in (curses.KEY_BACKSPACE, 127, 8):
                output_path = output_path[:-1]
            elif 32 <= key <= 126:
                output_path += chr(key)
            continue
            
        # Navigation
        if key in (ord('q'), ord('Q')): sys.exit(0)
        elif key == curses.KEY_UP: cursor_pos = max(0, cursor_pos - 1)
        elif key == curses.KEY_DOWN: cursor_pos = min(len(subtitles)-1, cursor_pos + 1)
        
        # Actions
        elif key == ord(' '): # Toggle Remove/Keep
            idx = subtitles[cursor_pos]['index']
            curr = state_map[idx]
            # Cycle: KEEP -> REMOVE -> KEEP (Convert is set via 'C')
            if curr == 'KEEP': state_map[idx] = 'REMOVE'
            elif curr == 'REMOVE': state_map[idx] = 'KEEP'
            elif curr == 'CONVERT': state_map[idx] = 'REMOVE' # Allow removing a convert
            
        elif key in (ord('a'), ord('A')): # Remove Non-English
            for s in subtitles:
                lang = s.get('tags', {}).get('language', 'und')
                if lang != 'eng':
                    state_map[s['index']] = 'REMOVE'
                    
        elif key in (ord('c'), ord('C')): # Convert Non-SRT
            for s in subtitles:
                codec = s.get('codec_name', '')
                if codec != 'subrip':
                    # Only mark if not already removed? Or override remove?
                    # Usually better to override 'KEEP', leave 'REMOVE' alone?
                    # Let's verify: User wants to convert all non-SRT.
                    # We should probably force it unless user explicitly removed it?
                    # Implementation: Mark CONVERT. User can toggle off later.
                    state_map[s['index']] = 'CONVERT'
        
        elif key in (ord('o'), ord('O')):
            edit_mode = True
            curses.curs_set(1)
            
        elif key in (ord('r'), ord('R')):
            if draw_confirmation_popup(stdscr, subtitles, state_map):
                break # Proceed to process
            else:
                # Just redraw menu loop
                pass

    return output_path, state_map

def main():
    parser = argparse.ArgumentParser(description="Interactive Subtitle Tool")
    parser.add_argument("-i", "--input", help="Input video file")
    parser.add_argument("-v", "--version", action="store_true", help="Show history")
    args = parser.parse_args()

    # Always print version
    print_version()
    if args.version:
        print(VERSION_HISTORY)
        sys.exit(0)
        
    if not args.input:
        print("Error: -i/--input required.")
        sys.exit(1)
        
    if not os.path.exists(args.input):
        print(f"Error: File not found.")
        sys.exit(1)

    streams = get_stream_info(args.input)
    if not any(s.get('codec_type') == 'subtitle' for s in streams):
        print("No subtitle tracks found.")
        sys.exit(0)

    try:
        result = curses.wrapper(tui_main, args)
    except KeyboardInterrupt:
        print("\nCancelled.")
        sys.exit(0)
        
    if not result: sys.exit(0)
    
    out_path, state_map = result
    
    # Final check if anything to do
    actions = [v for v in state_map.values() if v in ('REMOVE', 'CONVERT')]
    if not actions:
        print("No changes selected. Exiting.")
        sys.exit(0)
        
    process_remux(args.input, out_path, state_map)

if __name__ == "__main__":
    main()
