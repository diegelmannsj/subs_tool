def draw_menu(stdscr, full_path, subtitles, output_path, cursor_pos, edit_mode, move_mode, is_batch=False, file_idx=0, total_files=0, auto_del_ext=False):
    stdscr.erase() # Changed from clear() to prevent UI flickering
    h, w = stdscr.getmaxyx()
    
    counter = f"[{file_idx+1}/{total_files}] " if is_batch else ""
    header = f",subs_tool v{VERSION} - {counter}{full_path}"
    stdscr.addstr(0, 0, header[:w-1], curses.A_BOLD | curses.A_UNDERLINE)
    
    if move_mode:
        instr = "[UP/DOWN] Move Track | [M] Exit Move Mode"
        color = curses.color_pair(4)
    else:
        nav_hint = " | [L/R Arrows] Skip File" if is_batch else ""
        del_state = "ON" if auto_del_ext else "OFF"
        instr = f"[Space/Click] Toggle | [D] Auto-Del: {del_state} | [M] Move | [C] Convert | [R] Run | [Q] Quit{nav_hint}"
        color = curses.A_DIM
        
    stdscr.addstr(1, 0, instr[:w-1], color)
    stdscr.addstr(2, 0, "-" * (w-1))

    list_start_y = 3
    max_visible = h - 6
    scroll_offset = max(0, cursor_pos - max_visible + 1)
    
    for i in range(max_visible):
        idx_in_list = i + scroll_offset
        if idx_in_list >= len(subtitles): break
        
        sub = subtitles[idx_in_list]
        label = format_track_label(sub)
        status = sub['status']
        
        # Identification of "Ideal Candidates" (Text but not SRT)
        is_ideal_candidate = sub['is_text'] and sub['codec_raw'] != 'subrip'
        
        color = curses.color_pair(2) # Green KEEP
        check = "[ ] KEEP   "
        if status == 'REMOVE':
            color = curses.color_pair(1); check = "[*] REMOVE "
        elif status == 'CONVERT':
            color = curses.color_pair(3); check = "[C] CONVERT"
        elif status == 'EMBED':
            color = curses.color_pair(6); check = "[E] EMBED  "
        elif is_ideal_candidate and status == 'KEEP':
            # Conspicuous highlight for optimal conversion candidates currently set to KEEP
            color = curses.color_pair(5); check = "[!] KEEP* "
            
        style = color
        if (not sub['is_text'] or is_ideal_candidate) and status != 'REMOVE':
            style |= curses.A_BOLD

        if idx_in_list == cursor_pos and not edit_mode:
            if move_mode:
                style = curses.color_pair(4) | curses.A_BOLD
                check = " < MOVE >  "
            else:
                style |= curses.A_REVERSE
            
        line = f" {check} {label}"
        stdscr.addstr(list_start_y + i, 0, line[:w-1], style)

    out_y = h - 2
    lbl = "Output: "
    stdscr.addstr(out_y, 0, lbl, curses.A_BOLD)
    style_path = curses.A_REVERSE if edit_mode else curses.A_NORMAL
    disp_path = output_path
    avail = w - len(lbl) - 1
    if len(disp_path) > avail: disp_path = "..." + disp_path[-(avail-3):]
    stdscr.addstr(out_y, len(lbl), disp_path, style_path)
    stdscr.refresh()

def draw_confirmation_popup(stdscr, subtitles, is_batch=False, is_batch_identical=False):
    h, w = stdscr.getmaxyx()
    box_h, box_w = h - 4, w - 8
    start_y, start_x = 2, 4
    win = curses.newwin(box_h, box_w, start_y, start_x)
    win.keypad(True)
    win.box()
    
    title = "FINAL TRACK LIST PREVIEW"
    if is_batch: title += " (TEMPLATE FOR BATCH)"
    win.addstr(1, 2, title, curses.A_BOLD | curses.A_UNDERLINE)
    
    instr = "Press [Y]es to Proceed"
    if is_batch and is_batch_identical: instr += ", [A]pply to All"
    elif is_batch: instr += " (Batch mismatch - Apply All disabled)"
    instr += ", [N]o/Esc to Cancel"
    win.addstr(box_h-2, 2, instr)
    
    final_list = [s for s in subtitles if s['status'] != 'REMOVE']
    scroll_pos = 0
    max_lines = box_h - 4
    
    while True:
        for i in range(max_lines):
            idx = i + scroll_pos
            if idx >= len(final_list):
                win.addstr(2+i, 2, " " * (box_w - 4))
                continue
            sub = final_list[idx]
            prefix = f"{idx+1}. "
            lang_name = ISO_639_MAP.get(sub['lang'], sub['lang'])
            codec = sub['codec_friendly']
            note = ""
            attr = curses.color_pair(2)
            if sub['status'] == 'CONVERT':
                codec = "SRT"; note = " (Converted)"; attr = curses.color_pair(3)
            elif sub['status'] == 'EMBED':
                note = " (Embed & Del)"; attr = curses.color_pair(6)
            line = f"{prefix}{lang_name} [{codec}]{note}"
            win.addstr(2+i, 2, line[:box_w-4].ljust(box_w-4), attr)
        
        win.refresh()
        key = win.getch()
        if key in (ord('y'), ord('Y'), 10, 13): return 'Y'
        if key in (ord('n'), ord('N'), 27): return 'N'
        if is_batch and is_batch_identical and key in (ord('a'), ord('A')): return 'A'
        
        if key == curses.KEY_DOWN:
            if scroll_pos < len(final_list) - max_lines: scroll_pos += 1
        elif key == curses.KEY_UP:
            if scroll_pos > 0: scroll_pos -= 1

def init_subtitles(file_path):
    raw_streams = get_stream_info(file_path)
    subtitles = []
    
    if raw_streams:
        raw_subs = [s for s in raw_streams if s.get('codec_type') == 'subtitle']
        for s in raw_subs:
            codec_raw = s.get('codec_name', 'unknown')
            raw_title = s.get('tags', {}).get('title', '')
            
            # Scrub 'External' (and surrounding hyphens/spaces) from embedded titles
            clean_title = re.sub(r'(?i)[-\s]*\bexternal\b[-\s]*', ' ', raw_title).strip(' -_')
            
            subtitles.append({
                'original_index': s['index'],
                'is_external': False,
                'lang': s.get('tags', {}).get('language', 'und'),
                'title': clean_title,
                'codec_raw': codec_raw,
                'codec_friendly': SUBTITLE_CODEC_MAP.get(codec_raw, codec_raw),
                'is_text': codec_raw in TEXT_BASED_CODECS,
                'status': 'KEEP'
            })
    
    external_subs = scan_external_subs(file_path)
    subtitles.extend(external_subs)
    
    if not subtitles: return None
    return subtitles

def tui_main(stdscr, args, file_path, initial_subtitles=None, is_batch=False, file_idx=0, total_files=0, auto_del_ext=False, is_batch_identical=False, custom_out_path=None):
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_RED, -1)    # Remove
    curses.init_pair(2, curses.COLOR_GREEN, -1)  # Keep
    curses.init_pair(3, curses.COLOR_CYAN, -1)   # Convert
    curses.init_pair(4, curses.COLOR_YELLOW, -1) # Moving
    curses.init_pair(5, curses.COLOR_MAGENTA, -1) # Ideal Candidate Highlight
    curses.init_pair(6, curses.COLOR_YELLOW, -1) # Embed External Highlight
    curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
    
    curses.curs_set(0)
    stdscr.timeout(100)
    
    full_path = os.path.abspath(file_path)
    output_path = custom_out_path if custom_out_path else file_path
    
    # Load from persistence if available
    subtitles = initial_subtitles if initial_subtitles else init_subtitles(file_path)
    if not subtitles: return None
    
    # Apply global auto_del_ext if this is a fresh load and flag is true
    if not initial_subtitles and auto_del_ext:
        for s in subtitles:
            if s.get('is_external') and s['status'] == 'KEEP':
                s['status'] = 'EMBED'
    
    cursor_pos = 0
    edit_mode = False
    move_mode = False
    
    while True:
        draw_menu(stdscr, full_path, subtitles, output_path, cursor_pos, edit_mode, move_mode, is_batch, file_idx, total_files, auto_del_ext)
        
        key = stdscr.getch()
        
        # Idle wait loop to prevent constant redrawing and CPU waste
        while key == -1:
            key = stdscr.getch()
        
        if key == curses.KEY_MOUSE:
            try:
                _, mx, my, _, _ = curses.getmouse()
                list_start_y = 3
                max_visible = stdscr.getmaxyx()[0] - 6
                if list_start_y <= my < list_start_y + max_visible:
                    scroll_offset = max(0, cursor_pos - max_visible + 1)
                    actual_idx = (my - list_start_y) + scroll_offset
                    if 0 <= actual_idx < len(subtitles):
                        cursor_pos = actual_idx
                        if not move_mode:
                            sub = subtitles[cursor_pos]
                            if sub.get('is_external'):
                                if sub['status'] == 'KEEP': sub['status'] = 'EMBED'
                                elif sub['status'] == 'EMBED': sub['status'] = 'REMOVE'
                                else: sub['status'] = 'KEEP'
                            else:
                                if sub['status'] == 'KEEP': sub['status'] = 'REMOVE'
                                elif sub['status'] == 'REMOVE':
                                    if sub['is_text'] and sub['codec_raw'] != 'subrip': sub['status'] = 'CONVERT'
                                    else: sub['status'] = 'KEEP'
                                else: sub['status'] = 'KEEP'
                h, _ = stdscr.getmaxyx()
                if my == h - 2: edit_mode = True; curses.curs_set(1)
            except curses.error: pass
            continue

        if edit_mode:
            if key in (10, 13, 27): edit_mode = False; curses.curs_set(0)
            elif key in (curses.KEY_BACKSPACE, 127, 8): output_path = output_path[:-1]
            elif 32 <= key <= 126: output_path += chr(key)
            continue
            
        if move_mode:
            if key == curses.KEY_UP and cursor_pos > 0:
                subtitles[cursor_pos], subtitles[cursor_pos-1] = subtitles[cursor_pos-1], subtitles[cursor_pos]
                cursor_pos -= 1
            elif key == curses.KEY_DOWN and cursor_pos < len(subtitles) - 1:
                subtitles[cursor_pos], subtitles[cursor_pos+1] = subtitles[cursor_pos+1], subtitles[cursor_pos]
                cursor_pos += 1
            elif key in (ord('m'), ord('M'), 27, 10, 13): move_mode = False
            continue

        if key in (ord('q'), ord('Q')): sys.exit(0)
        elif key == curses.KEY_UP: cursor_pos = max(0, cursor_pos - 1)
        elif key == curses.KEY_DOWN: cursor_pos = min(len(subtitles)-1, cursor_pos + 1)
        
        elif key == curses.KEY_RIGHT and is_batch:
            if file_idx < total_files - 1: return "__NAV_NEXT__", subtitles, output_path, auto_del_ext
            else: curses.flash() # Notify user they are at the end
        elif key == curses.KEY_LEFT and is_batch:
            if file_idx > 0: return "__NAV_PREV__", subtitles, output_path, auto_del_ext
            else: curses.flash() # Notify user they are at the start

        elif key == ord(' '): 
            sub = subtitles[cursor_pos]
            if sub.get('is_external'):
                if sub['status'] == 'KEEP': sub['status'] = 'EMBED'
                elif sub['status'] == 'EMBED': sub['status'] = 'REMOVE'
                else: sub['status'] = 'KEEP'
            else:
                sub['status'] = 'REMOVE' if sub['status'] != 'REMOVE' else 'KEEP'
        elif key in (ord('d'), ord('D')):
            auto_del_ext = not auto_del_ext
            for s in subtitles:
                if s.get('is_external'):
                    if auto_del_ext and s['status'] == 'KEEP':
                        s['status'] = 'EMBED'
                    elif not auto_del_ext and s['status'] == 'EMBED':
                        s['status'] = 'KEEP'
        elif key in (ord('a'), ord('A')): 
            for s in subtitles:
                if s['lang'] != 'eng': s['status'] = 'REMOVE'
        elif key in (ord('c'), ord('C')): 
            sub = subtitles[cursor_pos]
            if sub['status'] == 'CONVERT': sub['status'] = 'KEEP'
            elif sub['is_text'] and sub['codec_raw'] != 'subrip': sub['status'] = 'CONVERT'
        elif key in (ord('m'), ord('M')): move_mode = True
        elif key in (ord('o'), ord('O')): edit_mode = True; curses.curs_set(1)
        elif key in (ord('r'), ord('R')):
            conf = draw_confirmation_popup(stdscr, subtitles, is_batch, is_batch_identical)
            if conf in ('Y', 'A'): return output_path, subtitles, conf, auto_del_ext
            
    return None

def scan_directory(path, recursive):
    vids = []
    exclude = ('.trickplay', '.bif', 'Backdrops', 'metadata')
    if recursive:
        for root, dirs, files in os.walk(path):
            dirs[:] = [d for d in dirs if d not in exclude]
            for f in files:
                if f.lower().endswith(VIDEO_EXTS): vids.append(os.path.join(root, f))
    else:
        for f in os.listdir(path):
            if f.lower().endswith(VIDEO_EXTS): vids.append(os.path.join(path, f))
    return sorted(vids)

def apply_template_to_file(new_subs, template_subs):
    final_subs = []
    for template_item in template_subs:
        match = next((s for s in new_subs if s['original_index'] == template_item['original_index']), None)
        if match:
            match['status'] = template_item['status']
            final_subs.append(match)
    return final_subs

def has_file_changed(fpath, out_path, original_subs, new_subs):
    if fpath != out_path:
        return True
        
    orig_order = [s['original_index'] for s in original_subs]
    new_order = [s['original_index'] for s in new_subs]
    if orig_order != new_order:
        return True
        
    for sub in new_subs:
        if sub.get('is_external'):
            if sub['status'] in ('KEEP', 'EMBED'):
                return True
        else:
            if sub['status'] in ('REMOVE', 'CONVERT'):
                return True
                
    return False

def main():
    global VERBOSITY
    print_version()

    parser = argparse.ArgumentParser(description="Interactive Subtitle Tool")
    parser.add_argument("path", nargs="?", help="Input file or directory")
    parser.add_argument("-i", "--input", help="Input video file")
    parser.add_argument("-d", "--dir", help="Input directory")
    parser.add_argument("-R", "--recursive", action="store_true", help="Recursive scan")
    parser.add_argument("-v", "--version", action="store_true", help="Show history")
    parser.add_argument("-q", "--quiet", action="store_true", help="Quiet Mode")
    parser.add_argument("-VV", "--very-verbose", action="store_true", help="Debug Mode")
    args = parser.parse_args()

    if args.version: print(VERSION_HISTORY); sys.exit(0)

    if args.path and not args.input and not args.dir:
        if os.path.isdir(args.path): args.dir = args.path
        else: args.input = args.path

    VERBOSITY = 0 if args.quiet else (2 if args.very_verbose else 1)
    
    files_found = []
    if args.input:
        if os.path.exists(args.input): files_found = [args.input]
        else: log("Error: File not found.", 0); sys.exit(1)
    elif args.dir:
        if os.path.exists(args.dir):
            files_found = scan_directory(args.dir, args.recursive)
        else: log("Error: Directory not found.", 0); sys.exit(1)
    else: log("Error: Input required.", 0); sys.exit(1)

    # Parallel Screening
    files_to_process = []
    preloaded_subs = {}
    is_batch_identical = True
    
    if len(files_found) > 1:
        log(f"Screening {len(files_found)} files for subtitle tracks...", 1)
        with ThreadPoolExecutor(max_workers=os.cpu_count()) as executor:
            future_to_file = {executor.submit(init_subtitles, f): f for f in files_found}
            done_count = 0
            for future in as_completed(future_to_file):
                res = future.result()
                f = future_to_file[future]
                if res: 
                    files_to_process.append(f)
                    preloaded_subs[f] = res
                done_count += 1
                sys.stdout.write(f"\r  -> Progress: {done_count}/{len(files_found)} screened...")
                sys.stdout.flush()
        files_to_process.sort() # Ensure consistent order
        log(f"\n  -> Found {len(files_to_process)} actionable files.", 1)
        if not files_to_process: sys.exit(0)
        
        signatures = set()
        for f in files_to_process:
            signatures.add(get_sub_signature(preloaded_subs[f]))
        is_batch_identical = (len(signatures) <= 1)
        if not is_batch_identical:
            log("  -> Note: Batch files have varying subtitle tracks. 'Apply All' will be disabled.", 1)
    else: 
        files_to_process = files_found
        for f in files_to_process:
            preloaded_subs[f] = init_subtitles(f)

    # Batch state and persistence
    apply_all_mode = False
    template_config = []
    session_persistence = {} # fpath: subs_list
    outpath_persistence = {} # fpath: custom_output_path
    auto_del_ext = False
    execute_batch = False

    # --- TUI Configuration Phase ---
    f_idx = 0
    while f_idx < len(files_to_process):
        fpath = files_to_process[f_idx]
        
        prev_subs = session_persistence.get(fpath)
        current_subs = prev_subs if prev_subs else copy.deepcopy(preloaded_subs[fpath])
        current_out = outpath_persistence.get(fpath, fpath)

        try:
            res = curses.wrapper(tui_main, args, fpath, current_subs, (len(files_to_process) > 1), f_idx, len(files_to_process), auto_del_ext, is_batch_identical, current_out)
        except KeyboardInterrupt: log("\nCancelled.", 0); sys.exit(0)
        
        if res and isinstance(res, tuple) and res[0] == "__NAV_NEXT__":
            session_persistence[fpath] = res[1]
            outpath_persistence[fpath] = res[2]
            auto_del_ext = res[3]
            f_idx += 1
        elif res and isinstance(res, tuple) and res[0] == "__NAV_PREV__":
            session_persistence[fpath] = res[1]
            outpath_persistence[fpath] = res[2]
            auto_del_ext = res[3]
            f_idx = max(0, f_idx - 1)
        elif not res:
            f_idx += 1
        else:
            out_path, subs_list, confirmation, auto_del_ext = res
            session_persistence[fpath] = subs_list
            outpath_persistence[fpath] = out_path
            
            if confirmation == 'A':
                apply_all_mode = True
                template_config = subs_list
            
            execute_batch = True
            break # Exit the TUI loop once Run is confirmed
            
    if not execute_batch:
        sys.exit(0)
        
    # --- Batch Execution Phase ---
    log("\n==================================================", 1)
    log("            STARTING BATCH EXECUTION              ", 1)
    log("==================================================", 1)

    for i, fpath in enumerate(files_to_process):
        log(f"\n[{i+1}/{len(files_to_process)}] Processing: {os.path.basename(fpath)}", 1)
        
        out_path = outpath_persistence.get(fpath, fpath)
        
        if apply_all_mode:
            baseline_subs = copy.deepcopy(preloaded_subs[fpath])
            subs = apply_template_to_file(baseline_subs, template_config)
        else:
            if fpath in session_persistence:
                subs = session_persistence[fpath] # Use user's manual edits
            else:
                subs = copy.deepcopy(preloaded_subs[fpath])
                if auto_del_ext: # Apply global default rules to skipped files
                    for s in subs:
                        if s.get('is_external') and s['status'] == 'KEEP':
                            s['status'] = 'EMBED'
                            
        if not has_file_changed(fpath, out_path, preloaded_subs[fpath], subs):
            log("  -> Skipped: No changes detected.", 1)
            continue
            
        process_remux(fpath, out_path, subs)

if __name__ == "__main__":
    main()
