#!/usr/bin/env python3
"""
,subs_tool - Interactive Subtitle Manager

A TUI tool to manually select, remove, convert, and reorder subtitle tracks.
Features fast conversion for text-based subs (ASS/SSA -> SRT).
Note: Image-based OCR (PGS/VobSub) has been removed for stability.

Author: Buzzy's Admin
Target System: Fedora Linux (buzzy)
"""

import curses
import argparse
import subprocess
import json
import sys
import os
import shutil
import time

# --- Configuration ---
TEMP_DIR = "/storage/temp/"
VERSION = "3.0.0"

VERSION_HISTORY = f"""
,subs_tool v{VERSION}
---------------------------------
v3.0.0 refactor(core): Remove OCR & Slim Down
        - REMOVED unreliable manual OCR pipeline (Tesseract/Image extraction).
        - [C]onvert now exclusively handles text-to-text conversion (ASS/SSA -> SRT).
        - Removed heavy dependencies and complex failure handling logic.
        - Script is now significantly lighter and faster.

v2.8.0 feat(ui): Mouse Support
v2.7.1 feat(ui): OCR Warning & Highlighting
"""

# --- Constants & Mappings ---
ISO_639_MAP = {
    'eng': 'English', 'jpn': 'Japanese', 'und': 'Undetermined',
    'fra': 'French', 'fre': 'French', 'deu': 'German', 'ger': 'German',
    'ita': 'Italian', 'spa': 'Spanish', 'kor': 'Korean',
    'chi': 'Chinese', 'zho': 'Chinese', 'rus': 'Russian',
    'por': 'Portuguese', 'vie': 'Vietnamese', 'tha': 'Thai',
    'swe': 'Swedish', 'nor': 'Norwegian', 'dan': 'Danish',
    'fin': 'Finnish', 'nld': 'Dutch', 'dut': 'Dutch',
    'pol': 'Polish', 'hin': 'Hindi', 'tur': 'Turkish',
    'ara': 'Arabic', 'heb': 'Hebrew', 'cze': 'Czech', 'ces': 'Czech',
    'gre': 'Greek', 'ell': 'Greek', 'hun': 'Hungarian', 'ind': 'Indonesian',
    'msa': 'Malay', 'may': 'Malay', 'rum': 'Romanian', 'ron': 'Romanian',
    'ukr': 'Ukrainian'
}

SUBTITLE_CODEC_MAP = {
    'subrip': 'SRT',
    'hdmv_pgs_subtitle': 'PGS',
    'dvd_subtitle': 'VobSub',
    'ass': 'ASS',
    'ssa': 'SSA',
    'mov_text': 'MovText',
    'webvtt': 'WebVTT',
    'eia_608': 'EIA-608',
    'dvb_subtitle': 'DVB'
}

TEXT_BASED_CODECS = {'ass', 'ssa', 'mov_text', 'webvtt', 'subrip', 'text'}
VIDEO_EXTS = ('.mkv', '.mp4', '.avi')
SUB_EXTS = ('.srt', '.sub', '.ass', '.ssa', '.vtt', '.idx') 

# --- Logging Helper ---
VERBOSITY = 1 

def log(msg, level=1):
    if VERBOSITY >= level:
        print(msg)

# --- Core Helper Functions ---

def print_version():
    log(f",subs_tool - Version {VERSION}", 1)
    log("-" * 30, 1)

def get_stream_info(file_path):
    cmd = ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_streams", file_path]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return json.loads(result.stdout).get('streams', [])
    except Exception:
        return []

def get_track_structure_signature(file_path):
    streams = get_stream_info(file_path)
    subs = [s for s in streams if s.get('codec_type') == 'subtitle']
    if not subs: return "NONE"
    
    sig_parts = [str(len(subs))]
    for s in subs:
        idx = s['index']
        codec = s.get('codec_name', 'unk')
        lang = s.get('tags', {}).get('language', 'und')
        sig_parts.append(f"{idx}:{codec}:{lang}")
    return "|".join(sig_parts)

def format_track_label(sub_dict):
    lang_name = ISO_639_MAP.get(sub_dict['lang'], sub_dict['lang'])
    codec = sub_dict['codec_friendly']
    type_tag = "[TXT]" if sub_dict['is_text'] else "[IMG]"
    title_str = f" - {sub_dict['title']}" if sub_dict['title'] else ""
    
    if sub_dict.get('is_external'):
        return f"[EXTERNAL] {lang_name} [{codec}] {type_tag} ({os.path.basename(sub_dict['file_path'])})"
    
    return f"Stream #{sub_dict['original_index']}: {lang_name} [{sub_dict['lang']}] [{codec}] {type_tag}{title_str}"

# --- Scanning External Subs ---

def scan_external_subs(video_path):
    base_dir = os.path.dirname(video_path)
    base_name = os.path.splitext(os.path.basename(video_path))[0]
    external_subs = []
    
    try:
        for f in os.listdir(base_dir):
            if f.startswith(base_name) and f.lower().endswith(SUB_EXTS):
                if f.lower().endswith('.idx'): continue
                full_path = os.path.join(base_dir, f)
                streams = get_stream_info(full_path)
                if streams:
                    s = streams[0]
                    codec_raw = s.get('codec_name', 'unknown')
                    lang = 'und'
                    parts = f.split('.')
                    if len(parts) > 2:
                        potential_lang = parts[-2].lower()
                        if len(potential_lang) == 3 and potential_lang in ISO_639_MAP:
                            lang = potential_lang
                        elif potential_lang in ['english', 'en']: lang = 'eng'
                    if s.get('tags', {}).get('language', 'und') != 'und':
                        lang = s.get('tags', {}).get('language')

                    external_subs.append({
                        'original_index': -1 * (len(external_subs) + 1),
                        'is_external': True,
                        'file_path': full_path,
                        'lang': lang,
                        'title': 'External',
                        'codec_raw': codec_raw,
                        'codec_friendly': SUBTITLE_CODEC_MAP.get(codec_raw, codec_raw),
                        'is_text': codec_raw in TEXT_BASED_CODECS,
                        'status': 'KEEP'
                    })
    except OSError: pass
    return external_subs

# --- Conversion Logic (Text Only) ---

def perform_text_conversion(input_file, stream_index, output_srt):
    log(f"    ... Converting Stream #{stream_index} (Text-Based) -> SRT...", 1)
    cmd = ["ffmpeg", "-nostdin", "-hide_banner", "-loglevel", "error", "-i", input_file, "-map", f"0:{stream_index}", "-c:s", "srt", "-y", output_srt]
    try:
        subprocess.run(cmd, check=True)
        return True
    except subprocess.CalledProcessError as e:
        log(f"    -> Conversion Failed: {e}", 1)
        return False

# --- Main Processing Logic ---

def smart_move_file(source, destination):
    try:
        src_dev = os.stat(source).st_dev
        dest_dir = os.path.dirname(os.path.abspath(destination))
        if not os.path.exists(dest_dir): os.makedirs(dest_dir)
        dest_dev = os.stat(dest_dir).st_dev
        
        if src_dev != dest_dev and shutil.which('pv'):
            log(f"Moving to: {destination} (via pv)...", 1)
            size = os.path.getsize(source)
            cmd = f"pv \"{source}\" -s {size} > \"{destination}\""
            subprocess.run(cmd, shell=True, check=True)
            os.remove(source)
            return True
        else:
            log(f"Moving to: {destination}...", 1)
            shutil.move(source, destination)
            return True
    except Exception as e:
        log(f"Error moving file: {e}", 1)
        return False

def process_remux(input_path, output_path, subs_list):
    os.makedirs(TEMP_DIR, exist_ok=True)
    base_name = os.path.basename(output_path)
    temp_final = os.path.join(TEMP_DIR, f"TEMP_REMUX_{int(time.time())}_{base_name}")
    ocr_work_dir = os.path.join(TEMP_DIR, "CONVERT_WORK")
    os.makedirs(ocr_work_dir, exist_ok=True)

    all_streams = get_stream_info(input_path)
    converted_inputs = {}

    # 1. Conversion Phase (Text Only)
    subs_to_convert = [s for s in subs_list if s['status'] == 'CONVERT']
    
    if subs_to_convert:
        log("\n--- Starting Conversion Phase ---", 1)
        for sub in subs_to_convert:
            idx = sub['original_index']
            if sub.get('is_external'):
                conv_input_path = sub['file_path']; conv_stream_idx = 0
            else:
                conv_input_path = input_path; conv_stream_idx = idx

            srt_path = os.path.join(ocr_work_dir, f"converted_{idx}.srt")
            success = False
            
            # Only Text-Based allowed now
            if sub['is_text']:
                success = perform_text_conversion(conv_input_path, conv_stream_idx, srt_path)
            else:
                # Should be caught by UI, but double check
                log(f"Warning: Skipping image-based stream #{idx}. OCR removed.", 1)
                sub['status'] = 'KEEP'

            if success:
                clean_title = f"{sub['title']} - SRT" if sub['title'] else "SRT"
                converted_inputs[idx] = {'path': srt_path, 'lang': sub['lang'], 'title': clean_title}

    # 2. Build FFmpeg Command
    log("\n--- Building Final File ---", 1)
    cmd = ["ffmpeg", "-hide_banner", "-v", "error", "-stats", "-i", input_path]
    
    sorted_conv_indices = sorted(converted_inputs.keys())
    input_file_map = {}
    for i, idx in enumerate(sorted_conv_indices):
        cmd.extend(["-i", converted_inputs[idx]['path']])
        input_file_map[idx] = i + 1

    extra_inputs_map = {}
    current_input_id = len(converted_inputs) + 1
    external_keeps = [s for s in subs_list if s.get('is_external') and s['status'] == 'KEEP']
    for ext in external_keeps:
        cmd.extend(["-i", ext['file_path']])
        extra_inputs_map[ext['original_index']] = current_input_id
        current_input_id += 1

    for s in all_streams:
        if s.get('codec_type') == 'video': cmd.extend(["-map", f"0:{s['index']}"])
    for s in all_streams:
        if s.get('codec_type') == 'audio': cmd.extend(["-map", f"0:{s['index']}"])
            
    current_out_idx = 0
    for sub in subs_list:
        status = sub['status']
        orig_idx = sub['original_index']
        
        if status == 'REMOVE': continue
            
        elif status == 'KEEP':
            if sub.get('is_external'):
                if orig_idx in extra_inputs_map:
                    input_idx = extra_inputs_map[orig_idx]
                    cmd.extend(["-map", f"{input_idx}:0"])
                    cmd.extend([f"-metadata:s:s:{current_out_idx}", f"language={sub['lang']}", f"-metadata:s:s:{current_out_idx}", f"title={sub['title']}"])
                    current_out_idx += 1
            else:
                cmd.extend(["-map", f"0:{orig_idx}"])
                current_out_idx += 1
            
        elif status == 'CONVERT':
            if orig_idx in converted_inputs:
                input_idx = input_file_map[orig_idx]
                cmd.extend(["-map", f"{input_idx}:0"])
                meta = converted_inputs[orig_idx]
                cmd.extend([f"-metadata:s:s:{current_out_idx}", f"language={meta['lang']}", f"-metadata:s:s:{current_out_idx}", f"title={meta['title']}"])
                current_out_idx += 1
            else:
                if not sub.get('is_external'):
                    cmd.extend(["-map", f"0:{orig_idx}"])
                    current_out_idx += 1

    cmd.extend(["-map", "0:d?", "-map", "0:t?"])
    cmd.extend(["-c", "copy", "-map_metadata", "0", "-y", temp_final])
    
    if VERBOSITY >= 2:
        log("\nFFmpeg Command:", 2)
        log(" ".join(cmd), 2)
    
    try:
        subprocess.run(cmd, check=True)
        if os.path.exists(temp_final) and os.path.getsize(temp_final) > 0:
            if smart_move_file(temp_final, output_path):
                log("Success!", 1)
        else: log("Error: Output empty.", 0)
    except subprocess.CalledProcessError as e: log(f"FFmpeg Error: {e}", 0)
    finally:
        if os.path.exists(ocr_work_dir): shutil.rmtree(ocr_work_dir)

# --- TUI Functions ---

def draw_menu(stdscr, filename, subtitles, output_path, cursor_pos, edit_mode, move_mode):
    stdscr.clear()
    h, w = stdscr.getmaxyx()
    header = f",subs_tool v{VERSION} - {filename}"
    stdscr.addstr(0, 0, header[:w-1], curses.A_BOLD | curses.A_UNDERLINE)
    
    if move_mode:
        instr = "[UP/DOWN] Move Track | [M] Exit Move Mode"
        color = curses.color_pair(4)
    else:
        instr = "[Space/Click] Toggle | [M] Move | [A] No-Eng | [C] Convert | [R] Run | [Q] Quit"
        color = curses.A_DIM
        
    stdscr.addstr(1, 0, instr[:w-1], color)
    stdscr.addstr(2, 0, "-" * (w-1))

    list_start_y = 3
    max_visible = h - 6
    scroll_offset = max(0, cursor_pos - max_visible + 1)
    
    for i in range(max_visible):
        idx_in_list = i + scroll_offset
        if idx_in_list >= len(subtitles): break
        
        sub = subtitles[idx_in_list]
        label = format_track_label(sub)
        status = sub['status']
        
        color = curses.color_pair(2) # Green KEEP
        check = "[ ] KEEP   "
        if status == 'REMOVE':
            color = curses.color_pair(1); check = "[*] REMOVE "
        elif status == 'CONVERT':
            color = curses.color_pair(3); check = "[C] CONVERT"
            
        style = color
        if not sub['is_text'] and status == 'KEEP':
            style |= curses.A_BOLD

        if idx_in_list == cursor_pos and not edit_mode:
            if move_mode:
                style = curses.color_pair(4) | curses.A_BOLD
                check = " < MOVE >  "
            else:
                style |= curses.A_REVERSE
            
        line = f" {check} {label}"
        stdscr.addstr(list_start_y + i, 0, line[:w-1], style)

    out_y = h - 2
    lbl = "Output: "
    stdscr.addstr(out_y, 0, lbl, curses.A_BOLD)
    style_path = curses.A_REVERSE if edit_mode else curses.A_NORMAL
    disp_path = output_path
    avail = w - len(lbl) - 1
    if len(disp_path) > avail: disp_path = "..." + disp_path[-(avail-3):]
    stdscr.addstr(out_y, len(lbl), disp_path, style_path)
    stdscr.refresh()

def draw_confirmation_popup(stdscr, subtitles, is_batch=False):
    h, w = stdscr.getmaxyx()
    box_h, box_w = h - 4, w - 8
    start_y, start_x = 2, 4
    win = curses.newwin(box_h, box_w, start_y, start_x)
    win.keypad(True)
    win.box()
    
    title = "FINAL TRACK LIST PREVIEW"
    if is_batch: title += " (TEMPLATE FOR BATCH)"
    win.addstr(1, 2, title, curses.A_BOLD | curses.A_UNDERLINE)
    
    instr = "Press [Y]es to Proceed"
    if is_batch: instr += ", [A]pply to All"
    instr += ", [N]o/Esc to Cancel"
    win.addstr(box_h-2, 2, instr)
    
    final_list = [s for s in subtitles if s['status'] != 'REMOVE']
    scroll_pos = 0
    max_lines = box_h - 4
    
    while True:
        for i in range(max_lines):
            idx = i + scroll_pos
            if idx >= len(final_list):
                win.addstr(2+i, 2, " " * (box_w - 4))
                continue
            sub = final_list[idx]
            prefix = f"{idx+1}. "
            lang_name = ISO_639_MAP.get(sub['lang'], sub['lang'])
            codec = sub['codec_friendly']
            note = ""
            attr = curses.color_pair(2)
            if sub['status'] == 'CONVERT':
                codec = "SRT"; note = " (Converted)"; attr = curses.color_pair(3)
            line = f"{prefix}{lang_name} [{codec}]{note}"
            win.addstr(2+i, 2, line[:box_w-4].ljust(box_w-4), attr)
        
        win.refresh()
        key = win.getch()
        if key in (ord('y'), ord('Y'), 10, 13): return 'Y'
        if key in (ord('n'), ord('N'), 27): return 'N'
        if is_batch and key in (ord('a'), ord('A')): return 'A'
        
        if key == curses.KEY_DOWN:
            if scroll_pos < len(final_list) - max_lines: scroll_pos += 1
        elif key == curses.KEY_UP:
            if scroll_pos > 0: scroll_pos -= 1

def draw_prompt_popup(stdscr, title, prompt):
    h, w = stdscr.getmaxyx()
    box_h, box_w = 8, 60
    start_y, start_x = (h - box_h) // 2, (w - box_w) // 2
    win = curses.newwin(box_h, box_w, start_y, start_x)
    win.box()
    win.addstr(1, 2, title[:box_w-4], curses.A_BOLD)
    win.addstr(3, 4, prompt[:box_w-6])
    win.addstr(5, 4, "[Y]es / [N]o")
    win.refresh()
    while True:
        key = stdscr.getch()
        if key in (ord('y'), ord('Y')): return True
        if key in (ord('n'), ord('N'), 27): return False

def init_subtitles(file_path):
    # 1. Internal Subs
    raw_streams = get_stream_info(file_path)
    subtitles = []
    
    if raw_streams:
        raw_subs = [s for s in raw_streams if s.get('codec_type') == 'subtitle']
        for s in raw_subs:
            codec_raw = s.get('codec_name', 'unknown')
            subtitles.append({
                'original_index': s['index'],
                'is_external': False,
                'lang': s.get('tags', {}).get('language', 'und'),
                'title': s.get('tags', {}).get('title', ''),
                'codec_raw': codec_raw,
                'codec_friendly': SUBTITLE_CODEC_MAP.get(codec_raw, codec_raw),
                'is_text': codec_raw in TEXT_BASED_CODECS,
                'status': 'KEEP'
            })
    
    # 2. External Subs
    external_subs = scan_external_subs(file_path)
    subtitles.extend(external_subs)
    
    if not subtitles: return None
    return subtitles

def tui_main(stdscr, args, file_path, is_batch=False):
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_RED, -1)    # Remove
    curses.init_pair(2, curses.COLOR_GREEN, -1)  # Keep
    curses.init_pair(3, curses.COLOR_CYAN, -1)   # Convert
    curses.init_pair(4, curses.COLOR_YELLOW, -1) # Moving
    curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
    
    curses.curs_set(0)
    stdscr.timeout(100)
    
    filename = os.path.basename(file_path)
    output_path = file_path
    
    subtitles = init_subtitles(file_path)
    if not subtitles: return None
    
    cursor_pos = 0
    edit_mode = False
    move_mode = False
    
    while True:
        draw_menu(stdscr, filename, subtitles, output_path, cursor_pos, edit_mode, move_mode)
        key = stdscr.getch()
        
        if key == curses.KEY_MOUSE:
            try:
                _, mx, my, _, _ = curses.getmouse()
                # Handle List Clicks (y start = 3)
                list_start_y = 3
                max_visible = stdscr.getmaxyx()[0] - 6
                
                # Check if click is within list area
                if list_start_y <= my < list_start_y + max_visible:
                    # Calculate index
                    scroll_offset = max(0, cursor_pos - max_visible + 1)
                    clicked_row = my - list_start_y
                    actual_idx = clicked_row + scroll_offset
                    
                    if 0 <= actual_idx < len(subtitles):
                        # Move cursor to clicked item
                        cursor_pos = actual_idx
                        # Toggle status (if not in move mode)
                        if not move_mode:
                            # Logic: KEEP -> REMOVE -> CONVERT (if text) -> KEEP
                            # If image: KEEP -> REMOVE -> KEEP
                            sub = subtitles[cursor_pos]
                            curr = sub['status']
                            
                            if curr == 'KEEP':
                                sub['status'] = 'REMOVE'
                            elif curr == 'REMOVE':
                                if sub['is_text'] and sub['codec_raw'] != 'subrip':
                                    sub['status'] = 'CONVERT'
                                else:
                                    sub['status'] = 'KEEP'
                            elif curr == 'CONVERT':
                                sub['status'] = 'KEEP'
                                
                # Check if click is on Output Path (h-2)
                h, _ = stdscr.getmaxyx()
                if my == h - 2:
                    edit_mode = True
                    curses.curs_set(1)
            except curses.error: pass
            continue

        if edit_mode:
            if key in (10, 13, 27): edit_mode = False; curses.curs_set(0)
            elif key in (curses.KEY_BACKSPACE, 127, 8): output_path = output_path[:-1]
            elif 32 <= key <= 126: output_path += chr(key)
            continue
            
        if move_mode:
            if key == curses.KEY_UP and cursor_pos > 0:
                subtitles[cursor_pos], subtitles[cursor_pos-1] = subtitles[cursor_pos-1], subtitles[cursor_pos]
                cursor_pos -= 1
            elif key == curses.KEY_DOWN and cursor_pos < len(subtitles) - 1:
                subtitles[cursor_pos], subtitles[cursor_pos+1] = subtitles[cursor_pos+1], subtitles[cursor_pos]
                cursor_pos += 1
            elif key in (ord('m'), ord('M'), 27, 10, 13): move_mode = False
            continue

        if key in (ord('q'), ord('Q')): sys.exit(0)
        elif key == curses.KEY_UP: cursor_pos = max(0, cursor_pos - 1)
        elif key == curses.KEY_DOWN: cursor_pos = min(len(subtitles)-1, cursor_pos + 1)
        
        elif key == ord(' '): 
            curr = subtitles[cursor_pos]['status']
            if curr == 'KEEP': subtitles[cursor_pos]['status'] = 'REMOVE'
            elif curr == 'REMOVE': subtitles[cursor_pos]['status'] = 'KEEP'
            elif curr == 'CONVERT': subtitles[cursor_pos]['status'] = 'REMOVE'
            
        elif key in (ord('a'), ord('A')): 
            for s in subtitles:
                if s['lang'] != 'eng': s['status'] = 'REMOVE'
                
        elif key in (ord('c'), ord('C')): 
            # Toggle Convert for CURRENT track only
            sub = subtitles[cursor_pos]
            if sub['status'] == 'CONVERT':
                sub['status'] = 'KEEP'
            else:
                if not sub['is_text']:
                    # Block image conversion
                    pass
                else:
                    if sub['codec_raw'] != 'subrip': # No point converting SRT to SRT
                        sub['status'] = 'CONVERT'
        
        elif key in (ord('m'), ord('M')): move_mode = True
        elif key in (ord('o'), ord('O')): edit_mode = True; curses.curs_set(1)
        
        elif key in (ord('r'), ord('R')):
            conf = draw_confirmation_popup(stdscr, subtitles, is_batch)
            if conf in ('Y', 'A'): return output_path, subtitles, conf
            
    return None

def scan_directory(path, recursive):
    vids = []
    if recursive:
        for root, dirs, files in os.walk(path):
            dirs[:] = [d for d in dirs if d not in ('.trickplay', '.bif', 'Backdrops', 'metadata')]
            for f in files:
                if f.lower().endswith(VIDEO_EXTS): vids.append(os.path.join(root, f))
    else:
        for f in os.listdir(path):
            if f.lower().endswith(VIDEO_EXTS): vids.append(os.path.join(path, f))
    return sorted(vids)

def apply_template_to_file(file_path, template_subs):
    new_subs = init_subtitles(file_path)
    if not new_subs: return None
    
    final_subs = []
    for template_item in template_subs:
        orig_idx = template_item['original_index']
        matching_sub = next((s for s in new_subs if s['original_index'] == orig_idx), None)
        if matching_sub:
            matching_sub['status'] = template_item['status']
            final_subs.append(matching_sub)
    return final_subs

def main():
    global VERBOSITY
    parser = argparse.ArgumentParser(description="Interactive Subtitle Tool")
    parser.add_argument("-i", "--input", help="Input video file")
    parser.add_argument("-d", "--dir", help="Input directory (Batch Mode)")
    parser.add_argument("-R", "--recursive", action="store_true", help="Recursive scan (for -d)")
    parser.add_argument("-v", "--version", action="store_true", help="Show history")
    
    parser.add_argument("-q", "--quiet", action="store_true", help="Quiet Mode")
    parser.add_argument("-V", "--verbose", action="store_true", default=True, help="Verbose Mode (Default)")
    parser.add_argument("-VV", "--very-verbose", action="store_true", help="Debug Mode (Show FFmpeg commands)")
    
    args = parser.parse_args()

    # Set Global Verbosity
    if args.quiet: VERBOSITY = 0
    elif args.very_verbose: VERBOSITY = 2
    else: VERBOSITY = 1

    print_version()
    if args.version: print(VERSION_HISTORY); sys.exit(0)
    
    files_to_process = []
    if args.input:
        if os.path.exists(args.input): files_to_process = [args.input]
        else: log("Error: File not found.", 0); sys.exit(1)
    elif args.dir:
        if os.path.exists(args.dir):
            files_to_process = scan_directory(args.dir, args.recursive)
            if not files_to_process: log("No video files found in directory.", 0); sys.exit(0)
        else: log("Error: Directory not found.", 0); sys.exit(1)
    else:
        log("Error: -i or -d required.", 0); sys.exit(1)

    # Batch State
    apply_all_mode = False
    template_signature = ""
    template_subs_config = []

    for idx, fpath in enumerate(files_to_process):
        log(f"\nProcessing {idx+1}/{len(files_to_process)}: {os.path.basename(fpath)}", 1)
        
        # Check if we can apply template
        if apply_all_mode:
            current_sig = get_track_structure_signature(fpath)
            if current_sig == template_signature:
                log("  -> Applying template settings...", 1)
                subs_list = apply_template_to_file(fpath, template_subs_config)
                process_remux(fpath, fpath, subs_list)
                continue
            else:
                log("  -> Structure mismatch! Falling back to interactive mode.", 1)
                time.sleep(1)

        # Interactive Mode
        try:
            res = curses.wrapper(tui_main, args, fpath, is_batch=(len(files_to_process) > 1))
        except KeyboardInterrupt: log("\nCancelled.", 0); sys.exit(0)
        
        if not res: 
            # Check why it failed (no subs vs user quit)
            subtitles = init_subtitles(fpath)
            if not subtitles:
                log("  -> Skipped (No subtitles found).", 1)
            else:
                log("  -> Skipped/Quit by user.", 1)
            
            if len(files_to_process) == 1: sys.exit(0)
            continue
            
        out_path, subs_list, confirmation = res
        
        if confirmation == 'A':
            apply_all_mode = True
            template_signature = get_track_structure_signature(fpath)
            template_subs_config = subs_list
            log("  -> Template saved. Applying to remaining files...", 1)
            
        process_remux(fpath, out_path, subs_list)

if __name__ == "__main__":
    main()
