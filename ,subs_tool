"""
,subs_tool - Interactive Subtitle Manager

A TUI tool to manually select, remove, convert, and reorder subtitle tracks.
Features robust OCR for converting image-based subs (PGS/VobSub) to SRT
and fast conversion for text-based subs (ASS/SSA).

Author: Buzzy's Admin
Target System: Fedora Linux (buzzy)
"""

import curses
import argparse
import subprocess
import json
import sys
import os
import shutil
import time
import math
import glob
from concurrent.futures import ThreadPoolExecutor

# --- Configuration ---
TEMP_DIR = "/storage/temp/"
VERSION = "2.3.0"

VERSION_HISTORY = f"""
,subs_tool v{VERSION}
---------------------------------
v2.3.0 feat(core): Reordering & In-Place Replacement
        - Added [M]ove mode to reorder subtitle tracks (Up/Down arrows).
        - Converted/Kept tracks are mapped in the user-defined order.
        - Confirmation popup now shows a detailed list of the final output tracks.
        - Fixed logic to ensure converted SRTs replace the original track position.

v2.2.0 feat(core): Enhanced Conversion Logic
        - [C]onvert key prompts for text-based inclusion.
"""

# --- Constants & Mappings ---
