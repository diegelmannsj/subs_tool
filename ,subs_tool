VIDEO_EXTS = ('.mkv', '.mp4', '.avi')
SUB_EXTS = ('.srt', '.sub', '.ass', '.ssa', '.vtt', '.idx') 

# --- Logging Helper ---
VERBOSITY = 1 

def log(msg, level=1):
    if VERBOSITY >= level:
        print(msg)

# --- Core Helper Functions ---

def print_version():
    # Always print the version regardless of VERBOSITY settings
    print(f",subs_tool - Version {VERSION}")
    print("-" * 30)

def get_stream_info(file_path):
    cmd = ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_streams", file_path]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return json.loads(result.stdout).get('streams', [])
    except Exception:
        return []

def get_track_structure_signature(file_path):
    streams = get_stream_info(file_path)
    subs = [s for s in streams if s.get('codec_type') == 'subtitle']
    if not subs: return "NONE"
    
    sig_parts = [str(len(subs))]
    for s in subs:
        idx = s['index']
        codec = s.get('codec_name', 'unk')
        lang = s.get('tags', {}).get('language', 'und')
        sig_parts.append(f"{idx}:{codec}:{lang}")
    return "|".join(sig_parts)

def get_sub_signature(subs_list):
    if not subs_list: return "NONE"
    sig_parts = [str(len(subs_list))]
    for s in subs_list:
        sig_parts.append(f"{s['original_index']}:{s['codec_raw']}:{s['lang']}")
    return "|".join(sig_parts)

def format_track_label(sub_dict):
    lang_name = ISO_639_MAP.get(sub_dict['lang'], sub_dict['lang'])
    codec = sub_dict['codec_friendly']
    type_tag = "[TXT]" if sub_dict['is_text'] else "[IMG]"
    title_str = f" - {sub_dict['title']}" if sub_dict['title'] else ""
    
    if sub_dict.get('is_external'):
        return f"[EXTERNAL] {lang_name} [{codec}] {type_tag} ({os.path.basename(sub_dict['file_path'])})"
    
    return f"Stream #{sub_dict['original_index']} [EMBEDDED]: {lang_name} [{sub_dict['lang']}] [{codec}] {type_tag}{title_str}"

def scan_external_subs(video_path):
    base_dir = os.path.dirname(video_path)
    base_name = os.path.splitext(os.path.basename(video_path))[0]
    external_subs = []
    
    try:
        for f in os.listdir(base_dir):
            if f.startswith(base_name) and f.lower().endswith(SUB_EXTS):
                if f.lower().endswith('.idx'): continue
                full_path = os.path.join(base_dir, f)
                streams = get_stream_info(full_path)
                if streams:
                    s = streams[0]
                    codec_raw = s.get('codec_name', 'unknown')
                    lang = 'und'
                    parts = f.split('.')
                    if len(parts) > 2:
                        potential_lang = parts[-2].lower()
                        if len(potential_lang) == 3 and potential_lang in ISO_639_MAP:
                            lang = potential_lang
                        elif potential_lang in ['english', 'en']: lang = 'eng'
                    if s.get('tags', {}).get('language', 'und') != 'und':
                        lang = s.get('tags', {}).get('language')

                    external_subs.append({
                        'original_index': -1 * (len(external_subs) + 1),
                        'is_external': True,
                        'file_path': full_path,
                        'lang': lang,
                        'title': 'External',
                        'codec_raw': codec_raw,
                        'codec_friendly': SUBTITLE_CODEC_MAP.get(codec_raw, codec_raw),
                        'is_text': codec_raw in TEXT_BASED_CODECS,
                        'status': 'KEEP'
                    })
    except OSError: pass
    return external_subs

def perform_text_conversion(input_file, stream_index, output_srt):
    log(f"    ... Converting Stream #{stream_index} (Text-Based) -> SRT...", 1)
    # Machine has QSV, but subtitle conversion is CPU-bound text processing; no QSV encoder for subtitles exists.
    cmd = ["ffmpeg", "-nostdin", "-hide_banner", "-loglevel", "error", "-i", input_file, "-map", f"0:{stream_index}", "-c:s", "srt", "-y", output_srt]
    try:
        subprocess.run(cmd, check=True)
        return True
    except subprocess.CalledProcessError as e:
        log(f"    -> Conversion Failed: {e}", 1)
        return False

def smart_move_file(source, destination):
    try:
        src_dev = os.stat(source).st_dev
        dest_dir = os.path.dirname(os.path.abspath(destination))
        if not os.path.exists(dest_dir): os.makedirs(dest_dir)
        dest_dev = os.stat(dest_dir).st_dev
        
        if src_dev != dest_dev and shutil.which('pv'):
            log(f"Moving to: {destination} (via pv)...", 1)
            size = os.path.getsize(source)
            cmd = f"pv \"{source}\" -s {size} > \"{destination}\""
            subprocess.run(cmd, shell=True, check=True)
            os.remove(source)
            return True
        else:
            log(f"Moving to: {destination}...", 1)
            shutil.move(source, destination)
            return True
    except Exception as e:
        log(f"Error moving file: {e}", 1)
        return False

def process_remux(input_path, output_path, subs_list):
    os.makedirs(TEMP_DIR, exist_ok=True)
    base_name = os.path.basename(output_path)
    temp_final = os.path.join(TEMP_DIR, f"TEMP_REMUX_{int(time.time())}_{base_name}")
    ocr_work_dir = os.path.join(TEMP_DIR, "CONVERT_WORK")
    os.makedirs(ocr_work_dir, exist_ok=True)

    all_streams = get_stream_info(input_path)
    converted_inputs = {}

    subs_to_convert = [s for s in subs_list if s['status'] == 'CONVERT']
    
    if subs_to_convert:
        log("\n--- Starting Conversion Phase ---", 1)
        for sub in subs_to_convert:
            idx = sub['original_index']
            if sub.get('is_external'):
                conv_input_path = sub['file_path']; conv_stream_idx = 0
            else:
                conv_input_path = input_path; conv_stream_idx = idx

            srt_path = os.path.join(ocr_work_dir, f"converted_{idx}.srt")
            success = False
            
            if sub['is_text']:
                success = perform_text_conversion(conv_input_path, conv_stream_idx, srt_path)
            else:
                log(f"Warning: Skipping image-based stream #{idx}. OCR removed.", 1)
                sub['status'] = 'KEEP'

            if success:
                clean_title = f"{sub['title']} - SRT" if sub['title'] else "SRT"
                converted_inputs[idx] = {'path': srt_path, 'lang': sub['lang'], 'title': clean_title}

    log("\n--- Building Final File ---", 1)
    # مشین ہیز QSV (Machine has QSV); however, remuxing (-c copy) does not use it.
    cmd = ["ffmpeg", "-hide_banner", "-v", "error", "-stats", "-i", input_path]
    
    sorted_conv_indices = sorted(converted_inputs.keys())
    input_file_map = {}
    for i, idx in enumerate(sorted_conv_indices):
        cmd.extend(["-i", converted_inputs[idx]['path']])
        input_file_map[idx] = i + 1

    extra_inputs_map = {}
    current_input_id = len(converted_inputs) + 1
    # Both KEEP and EMBED status for external files will be mapped in
    external_keeps = [s for s in subs_list if s.get('is_external') and s['status'] in ('KEEP', 'EMBED')]
    for ext in external_keeps:
        cmd.extend(["-i", ext['file_path']])
        extra_inputs_map[ext['original_index']] = current_input_id
        current_input_id += 1

    for s in all_streams:
        if s.get('codec_type') == 'video': cmd.extend(["-map", f"0:{s['index']}"])
    for s in all_streams:
        if s.get('codec_type') == 'audio': cmd.extend(["-map", f"0:{s['index']}"])
            
    current_out_idx = 0
    for sub in subs_list:
        status = sub['status']
        orig_idx = sub['original_index']
        
        if status == 'REMOVE': continue
        elif status in ('KEEP', 'EMBED'):
            if sub.get('is_external'):
                if orig_idx in extra_inputs_map:
                    input_idx = extra_inputs_map[orig_idx]
                    cmd.extend(["-map", f"{input_idx}:0"])
                    cmd.extend([f"-metadata:s:s:{current_out_idx}", f"language={sub['lang']}", f"-metadata:s:s:{current_out_idx}", f"title={sub['title']}"])
                    current_out_idx += 1
            else:
                cmd.extend(["-map", f"0:{orig_idx}"])
                current_out_idx += 1
        elif status == 'CONVERT':
            if orig_idx in converted_inputs:
                input_idx = input_file_map[orig_idx]
                cmd.extend(["-map", f"{input_idx}:0"])
                meta = converted_inputs[orig_idx]
                cmd.extend([f"-metadata:s:s:{current_out_idx}", f"language={meta['lang']}", f"-metadata:s:s:{current_out_idx}", f"title={meta['title']}"])
                current_out_idx += 1
            else:
                if not sub.get('is_external'):
                    cmd.extend(["-map", f"0:{orig_idx}"])
                    current_out_idx += 1

    cmd.extend(["-map", "0:d?", "-map", "0:t?"])
    cmd.extend(["-c", "copy", "-map_metadata", "0", "-y", temp_final])
    
    try:
        subprocess.run(cmd, check=True)
        if os.path.exists(temp_final) and os.path.getsize(temp_final) > 0:
            if smart_move_file(temp_final, output_path):
                log("Success!", 1)
                
                # Auto-cleanup for EMBED files after successful move
                for ext in external_keeps:
                    if ext['status'] == 'EMBED':
                        try:
                            os.remove(ext['file_path'])
                            log(f"Cleaned up external sub: {ext['file_path']}", 1)
                        except OSError as e:
                            log(f"Warning: Failed to delete {ext['file_path']}: {e}", 0)
        else: log("Error: Output empty.", 0)
    except subprocess.CalledProcessError as e: log(f"FFmpeg Error: {e}", 0)
    finally:
        if os.path.exists(ocr_work_dir): shutil.rmtree(ocr_work_dir)

