# --- Logging Helper ---
VERBOSITY = 1 

def log(msg, level=1):
    if VERBOSITY >= level:
        print(msg)

# --- Core Helper Functions ---

def print_version():
    # Always print the version regardless of VERBOSITY settings
    print(f",subs_tool - Version {VERSION}")
    print("-" * 30)

def get_stream_info(file_path):
    cmd = ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_streams", file_path]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return json.loads(result.stdout).get('streams', [])
    except Exception:
        return []

def get_media_signature(audio_list, subs_list):
    sig_parts = []
    if audio_list:
        sig_parts.append(str(len(audio_list)))
        for a in audio_list: sig_parts.append(f"{a['original_index']}:{a['codec_raw']}:{a['lang']}")
    if subs_list:
        sig_parts.append(str(len(subs_list)))
        for s in subs_list: sig_parts.append(f"{s['original_index']}:{s['codec_raw']}:{s['lang']}")
    return "|".join(sig_parts) if sig_parts else "NONE"

def format_track_label(track_dict, track_type="Subtitle"):
    lang_name = ISO_639_MAP.get(track_dict['lang'], track_dict['lang'])
    codec = track_dict.get('codec_friendly', track_dict.get('codec_raw', ''))
    title_str = f" - {track_dict['title']}" if track_dict.get('title') else ""
    
    if track_type == "Audio":
        channels = track_dict.get('channels', 'unknown')
        return f"Stream #{track_dict['original_index']}: {lang_name} [{track_dict['lang']}] [{codec}] ({channels} channels){title_str}"
    
    type_tag = "[TXT]" if track_dict['is_text'] else "[IMG]"
    
    if track_dict.get('is_external'):
        return f"[EXTERNAL] {lang_name} [{codec}] {type_tag} ({os.path.basename(track_dict['file_path'])})"
    
    return f"Stream #{track_dict['original_index']} [EMBEDDED]: {lang_name} [{track_dict['lang']}] [{codec}] {type_tag}{title_str}"

def scan_external_subs(video_path):
    abs_video_path = os.path.abspath(video_path)
    base_dir = os.path.dirname(abs_video_path)
    base_name = os.path.splitext(os.path.basename(abs_video_path))[0]
    external_subs = []
    
    try:
        for f in os.listdir(base_dir):
            if f.startswith(base_name) and f.lower().endswith(SUB_EXTS):
                if f.lower().endswith('.idx'): continue
                full_path = os.path.join(base_dir, f)
                streams = get_stream_info(full_path)
                if streams:
                    s = streams[0]
                    codec_raw = s.get('codec_name', 'unknown')
                    lang = 'und'
                    parts = f.split('.')
                    if len(parts) > 2:
                        potential_lang = parts[-2].lower()
                        if len(potential_lang) == 3 and potential_lang in ISO_639_MAP:
                            lang = potential_lang
                        elif potential_lang in ['english', 'en']: lang = 'eng'
                    if s.get('tags', {}).get('language', 'und') != 'und':
                        lang = s.get('tags', {}).get('language')

                    external_subs.append({
                        'original_index': -1 * (len(external_subs) + 1),
                        'is_external': True,
                        'file_path': full_path,
                        'lang': lang,
                        'title': 'External',
                        'codec_raw': codec_raw,
                        'codec_friendly': SUBTITLE_CODEC_MAP.get(codec_raw, codec_raw),
                        'is_text': codec_raw in TEXT_BASED_CODECS,
                        'status': 'KEEP'
                    })
    except OSError: pass
    return external_subs

def perform_text_conversion(input_file, stream_index, output_srt):
    log(f"    ... Converting Stream #{stream_index} (Text-Based) -> SRT...", 1)
    # Machine has QSV, but subtitle conversion is CPU-bound text processing; no QSV encoder for subtitles exists.
    cmd = ["ffmpeg", "-nostdin", "-hide_banner", "-loglevel", "error", "-i", input_file, "-map", f"0:{stream_index}", "-c:s", "srt", "-y", output_srt]
    try:
        subprocess.run(cmd, check=True)
        return True
    except subprocess.CalledProcessError as e:
        log(f"    -> Conversion Failed: {e}", 1)
        return False

def smart_move_file(source, destination):
    try:
        src_dev = os.stat(source).st_dev
        dest_dir = os.path.dirname(os.path.abspath(destination))
        if not os.path.exists(dest_dir): os.makedirs(dest_dir)
        dest_dev = os.stat(dest_dir).st_dev
        
        if src_dev != dest_dev and shutil.which('pv'):
            log(f"Moving to: {destination} (via pv)...", 1)
            size = os.path.getsize(source)
            cmd = f"pv \"{source}\" -s {size} > \"{destination}\""
            subprocess.run(cmd, shell=True, check=True)
            os.remove(source)
            return True
        else:
            log(f"Moving to: {destination}...", 1)
            shutil.move(source, destination)
            return True
    except Exception as e:
        log(f"Error moving file: {e}", 1)
        return False

def process_remux(input_path, output_path, subs_list, audio_list=None):
    os.makedirs(TEMP_DIR, exist_ok=True)
    base_name = os.path.basename(output_path)
    temp_final = os.path.join(TEMP_DIR, f"TEMP_REMUX_{int(time.time())}_{base_name}")
    ocr_work_dir = os.path.join(TEMP_DIR, "CONVERT_WORK")
    os.makedirs(ocr_work_dir, exist_ok=True)

    all_streams = get_stream_info(input_path)
    converted_inputs = {}

    subs_to_convert = [s for s in subs_list if s['status'] == 'CONVERT']
    
    if subs_to_convert:
        log("\n--- Starting Conversion Phase ---", 1)
        for sub in subs_to_convert:
            idx = sub['original_index']
            if sub.get('is_external'):
                conv_input_path = sub['file_path']; conv_stream_idx = 0
            else:
                conv_input_path = input_path; conv_stream_idx = idx

            srt_path = os.path.join(ocr_work_dir, f"converted_{idx}.srt")
            success = False
            
            if sub['is_text']:
                success = perform_text_conversion(conv_input_path, conv_stream_idx, srt_path)
            else:
                log(f"Warning: Skipping image-based stream #{idx}. OCR removed.", 1)
                sub['status'] = 'KEEP'

            if success:
                clean_title = f"{sub['title']} - SRT" if sub['title'] else "SRT"
                converted_inputs[idx] = {'path': srt_path, 'lang': sub['lang'], 'title': clean_title}

    log("\n--- Building Final File ---", 1)
    # مشین ہیز QSV (Machine has QSV); however, remuxing (-c copy) uses near-zero CPU and bypasses transcoders entirely.
    cmd = ["ffmpeg", "-hide_banner", "-v", "error", "-stats", "-i", input_path]
    
    sorted_conv_indices = sorted(converted_inputs.keys())
    input_file_map = {}
    for i, idx in enumerate(sorted_conv_indices):
        cmd.extend(["-i", converted_inputs[idx]['path']])
        input_file_map[idx] = i + 1

    extra_inputs_map = {}
    current_input_id = len(converted_inputs) + 1
    external_keeps = [s for s in subs_list if s.get('is_external') and s['status'] in ('KEEP', 'EMBED')]
    for ext in external_keeps:
        cmd.extend(["-i", ext['file_path']])
        extra_inputs_map[ext['original_index']] = current_input_id
        current_input_id += 1

    for s in all_streams:
        if s.get('codec_type') == 'video': cmd.extend(["-map", f"0:{s['index']}"])
            
    # Audio Map logic
    audio_changed = False
    if audio_list:
        orig_order = [a['original_index'] for a in all_streams if a.get('codec_type') == 'audio']
        new_order = [a['original_index'] for a in audio_list]
        removed = any(a['status'] == 'REMOVE' for a in audio_list)
        if orig_order != new_order or removed:
            audio_changed = True

    if audio_changed:
        audio_kept = [a for a in audio_list if a['status'] != 'REMOVE']
        for i, a in enumerate(audio_kept):
            cmd.extend(["-map", f"0:{a['original_index']}"])
            disp = "default" if i == 0 else "0"
            cmd.extend([f"-disposition:a:{i}", disp])
    else:
        for s in all_streams:
            if s.get('codec_type') == 'audio': cmd.extend(["-map", f"0:{s['index']}"])
            
    current_out_idx = 0
    for sub in subs_list:
        status = sub['status']
        orig_idx = sub['original_index']
        
        if status == 'REMOVE': continue
        elif status in ('KEEP', 'EMBED'):
            if sub.get('is_external'):
                if orig_idx in extra_inputs_map:
                    input_idx = extra_inputs_map[orig_idx]
                    cmd.extend(["-map", f"{input_idx}:0"])
                    cmd.extend([f"-metadata:s:s:{current_out_idx}", f"language={sub['lang']}", f"-metadata:s:s:{current_out_idx}", f"title={sub['title']}"])
                    current_out_idx += 1
            else:
                cmd.extend(["-map", f"0:{orig_idx}"])
                current_out_idx += 1
        elif status == 'CONVERT':
            if orig_idx in converted_inputs:
                input_idx = input_file_map[orig_idx]
                cmd.extend(["-map", f"{input_idx}:0"])
                meta = converted_inputs[orig_idx]
                cmd.extend([f"-metadata:s:s:{current_out_idx}", f"language={meta['lang']}", f"-metadata:s:s:{current_out_idx}", f"title={meta['title']}"])
                current_out_idx += 1
            else:
                if not sub.get('is_external'):
                    cmd.extend(["-map", f"0:{orig_idx}"])
                    current_out_idx += 1

    cmd.extend(["-map", "0:d?", "-map", "0:t?"])
    cmd.extend(["-c", "copy", "-map_metadata", "0", "-y", temp_final])
    
    try:
        subprocess.run(cmd, check=True)
        if os.path.exists(temp_final) and os.path.getsize(temp_final) > 0:
            if smart_move_file(temp_final, output_path):
                log("Success!", 1)
                
                # Cleanup original AVI if we converted to MKV
                if input_path != output_path and input_path.lower().endswith('.avi') and output_path.lower().endswith('.mkv'):
                    if os.path.exists(input_path):
                        try:
                            os.remove(input_path)
                            log(f"Cleaned up original AVI file: {os.path.basename(input_path)}", 1)
                        except OSError as e:
                            log(f"Warning: Failed to delete original AVI {os.path.basename(input_path)}: {e}", 0)
                
                # Auto-cleanup for EMBED files after successful move
                for ext in external_keeps:
                    if ext['status'] == 'EMBED':
                        try:
                            os.remove(ext['file_path'])
                            log(f"Cleaned up external sub: {ext['file_path']}", 1)
                        except OSError as e:
                            log(f"Warning: Failed to delete {ext['file_path']}: {e}", 0)
        else: log("Error: Output empty.", 0)
    except subprocess.CalledProcessError as e: log(f"FFmpeg Error: {e}", 0)
    finally:
        if os.path.exists(ocr_work_dir): shutil.rmtree(ocr_work_dir)

# --- TUI Functions ---

def draw_menu(stdscr, full_path, tracks, output_path, cursor_pos, edit_mode, move_mode, is_batch=False, file_idx=0, total_files=0, auto_del_ext=False, track_type="Subtitle"):
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    
    counter = f"[{file_idx+1}/{total_files}] " if is_batch else ""
    header = f",subs_tool v{VERSION} - [{track_type.upper()}] {counter}{full_path}"
    stdscr.addstr(0, 0, header[:w-1], curses.A_BOLD | curses.A_UNDERLINE)
    
    if move_mode:
        instr = "[UP/DOWN] Move Track | [M] Exit Move Mode"
        color = curses.color_pair(4)
    else:
        nav_hint = " | [L/R Arrows] Skip File" if is_batch else ""
        if track_type == "Subtitle":
            del_state = "ON" if auto_del_ext else "OFF"
            instr = f"[Space/Click] Toggle | [D] Auto-Del: {del_state} | [M] Move | [C] Convert | [Enter] Run | [Q] Quit{nav_hint}"
        else:
            instr = f"[Space/Click] Toggle | [A] Auto-remove non-Eng | [M] Move | [Enter] Run/Next | [Q] Quit{nav_hint}"
        color = curses.A_DIM
        
    stdscr.addstr(1, 0, instr[:w-1], color)
    stdscr.addstr(2, 0, "-" * (w-1))

    list_start_y = 3
    max_visible = h - 6
    scroll_offset = max(0, cursor_pos - max_visible + 1)
    
    for i in range(max_visible):
        idx_in_list = i + scroll_offset
        if idx_in_list >= len(tracks): break
        
        track = tracks[idx_in_list]
        label = format_track_label(track, track_type)
        status = track['status']
        
        is_ideal_candidate = False
        if track_type == "Subtitle":
            is_ideal_candidate = track['is_text'] and track['codec_raw'] != 'subrip'
        
        color = curses.color_pair(2) # Green KEEP
        check = "[ ] KEEP   "
        if status == 'REMOVE':
            color = curses.color_pair(1); check = "[*] REMOVE "
        elif status == 'CONVERT':
            color = curses.color_pair(3); check = "[C] CONVERT"
        elif status == 'EMBED':
            color = curses.color_pair(6); check = "[E] EMBED  "
        elif is_ideal_candidate and status == 'KEEP':
            color = curses.color_pair(5); check = "[!] KEEP* "
            
        style = color
        if track_type == "Audio":
            style |= curses.A_BOLD
        elif (not track['is_text'] or is_ideal_candidate) and status != 'REMOVE':
            style |= curses.A_BOLD

        if idx_in_list == cursor_pos and not edit_mode:
            if move_mode:
                style = curses.color_pair(4) | curses.A_BOLD
                check = " < MOVE >  "
            else:
                style |= curses.A_REVERSE
            
        line = f" {check} {label}"
        stdscr.addstr(list_start_y + i, 0, line[:w-1], style)

    out_y = h - 2
    lbl = "Output: "
    stdscr.addstr(out_y, 0, lbl, curses.A_BOLD)
    style_path = curses.A_REVERSE if edit_mode else curses.A_NORMAL
    disp_path = output_path
    avail = w - len(lbl) - 1
    if len(disp_path) > avail: disp_path = "..." + disp_path[-(avail-3):]
    stdscr.addstr(out_y, len(lbl), disp_path, style_path)
    stdscr.refresh()

def draw_confirmation_popup(stdscr, tracks, is_batch=False, is_batch_identical=False, track_type="Subtitle"):
    h, w = stdscr.getmaxyx()
    box_h, box_w = h - 4, w - 8
    start_y, start_x = 2, 4
    win = curses.newwin(box_h, box_w, start_y, start_x)
    win.keypad(True)
    win.box()
    
    title = f"FINAL {track_type.upper()} TRACK LIST PREVIEW"
    if is_batch: title += " (TEMPLATE FOR BATCH)"
    win.addstr(1, 2, title, curses.A_BOLD | curses.A_UNDERLINE)
    
    instr = "Press [Y]es to Proceed"
    if is_batch and is_batch_identical: instr += ", [A]pply to All"
    elif is_batch: instr += " (Batch mismatch - Apply All disabled)"
    instr += ", [N]o/Esc to Cancel"
    win.addstr(box_h-2, 2, instr)
    
    final_list = [s for s in tracks if s['status'] != 'REMOVE']
    scroll_pos = 0
    max_lines = box_h - 4
    
    while True:
        for i in range(max_lines):
            idx = i + scroll_pos
            if idx >= len(final_list):
                win.addstr(2+i, 2, " " * (box_w - 4))
                continue
            sub = final_list[idx]
            prefix = f"{idx+1}. "
            lang_name = ISO_639_MAP.get(sub['lang'], sub['lang'])
            codec = sub.get('codec_friendly', sub.get('codec_raw', ''))
            note = ""
            attr = curses.color_pair(2)
            
            if track_type == "Audio":
                channels = sub.get('channels', 'unknown')
                line = f"{prefix}{lang_name} [{codec}] ({channels} channels)"
            else:
                if sub['status'] == 'CONVERT':
                    codec = "SRT"; note = " (Converted)"; attr = curses.color_pair(3)
                elif sub['status'] == 'EMBED':
                    note = " (Embed & Del)"; attr = curses.color_pair(6)
                line = f"{prefix}{lang_name} [{codec}]{note}"
                
            win.addstr(2+i, 2, line[:box_w-4].ljust(box_w-4), attr)
        
        win.refresh()
        key = win.getch()
        if key in (ord('y'), ord('Y'), 10, 13): return 'Y'
        if key in (ord('n'), ord('N'), 27): return 'N'
        if is_batch and is_batch_identical and key in (ord('a'), ord('A')): return 'A'
        
        if key == curses.KEY_DOWN:
            if scroll_pos < len(final_list) - max_lines: scroll_pos += 1
        elif key == curses.KEY_UP:
            if scroll_pos > 0: scroll_pos -= 1

def init_media_tracks(file_path):
    raw_streams = get_stream_info(file_path)
    audio_tracks = []
    sub_tracks = []
    
    if raw_streams:
        for s in raw_streams:
            if s.get('codec_type') == 'audio':
                codec_raw = s.get('codec_name', 'unknown')
                channels = s.get('channels', 'unknown')
                
                # Scrub 'External' or messy titles from embedded audio as well
                raw_title = s.get('tags', {}).get('title', '')
                clean_title = re.sub(r'(?i)[-\s]*\bexternal\b[-\s]*', ' ', raw_title).strip(' -_')

                audio_tracks.append({
                    'original_index': s['index'],
                    'is_external': False,
                    'lang': s.get('tags', {}).get('language', 'und'),
                    'title': clean_title,
                    'codec_raw': codec_raw,
                    'channels': channels,
                    'codec_friendly': codec_raw.upper(),
                    'is_text': False,
                    'status': 'KEEP'
                })
            elif s.get('codec_type') == 'subtitle':
                codec_raw = s.get('codec_name', 'unknown')
                raw_title = s.get('tags', {}).get('title', '')
                clean_title = re.sub(r'(?i)[-\s]*\bexternal\b[-\s]*', ' ', raw_title).strip(' -_')
                
                sub_tracks.append({
                    'original_index': s['index'],
                    'is_external': False,
                    'lang': s.get('tags', {}).get('language', 'und'),
                    'title': clean_title,
                    'codec_raw': codec_raw,
                    'codec_friendly': SUBTITLE_CODEC_MAP.get(codec_raw, codec_raw),
                    'is_text': codec_raw in TEXT_BASED_CODECS,
                    'status': 'KEEP'
                })
                
    external_subs = scan_external_subs(file_path)
    sub_tracks.extend(external_subs)
    
    return audio_tracks, sub_tracks

def tui_main(stdscr, args, file_path, initial_tracks=None, is_batch=False, file_idx=0, total_files=0, auto_del_ext=False, is_batch_identical=False, custom_out_path=None, track_type="Subtitle", has_next_phase=False):
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_RED, -1)    # Remove
    curses.init_pair(2, curses.COLOR_GREEN, -1)  # Keep
    curses.init_pair(3, curses.COLOR_CYAN, -1)   # Convert
    curses.init_pair(4, curses.COLOR_YELLOW, -1) # Moving
    curses.init_pair(5, curses.COLOR_MAGENTA, -1) # Ideal Candidate Highlight
    curses.init_pair(6, curses.COLOR_YELLOW, -1) # Embed External Highlight
    curses.mousemask(curses.ALL_MOUSE_EVENTS | curses.REPORT_MOUSE_POSITION)
    
    curses.curs_set(0)
    stdscr.timeout(100)
    
    full_path = os.path.abspath(file_path)
    output_path = custom_out_path if custom_out_path else full_path
    
    if output_path.lower().endswith('.avi'):
        output_path = output_path[:-4] + '.mkv'
    
    tracks = initial_tracks if initial_tracks else []
    if not tracks: return None
    
    if track_type == "Subtitle" and not initial_tracks and auto_del_ext:
        for s in tracks:
            if s.get('is_external') and s['status'] == 'KEEP':
                s['status'] = 'EMBED'
    
    cursor_pos = 0
    edit_mode = False
    move_mode = False
    
    while True:
        draw_menu(stdscr, full_path, tracks, output_path, cursor_pos, edit_mode, move_mode, is_batch, file_idx, total_files, auto_del_ext, track_type)
        
        key = stdscr.getch()
        
        while key == -1:
            key = stdscr.getch()
        
        if key == curses.KEY_MOUSE:
            try:
                _, mx, my, _, _ = curses.getmouse()
                list_start_y = 3
                max_visible = stdscr.getmaxyx()[0] - 6
                if list_start_y <= my < list_start_y + max_visible:
                    scroll_offset = max(0, cursor_pos - max_visible + 1)
                    actual_idx = (my - list_start_y) + scroll_offset
                    if 0 <= actual_idx < len(tracks):
                        cursor_pos = actual_idx
                        if not move_mode:
                            sub = tracks[cursor_pos]
                            if track_type == "Subtitle":
                                if sub.get('is_external'):
                                    if sub['status'] == 'KEEP': sub['status'] = 'EMBED'
                                    elif sub['status'] == 'EMBED': sub['status'] = 'REMOVE'
                                    else: sub['status'] = 'KEEP'
                                else:
                                    if sub['status'] == 'KEEP': sub['status'] = 'REMOVE'
                                    elif sub['status'] == 'REMOVE':
                                        if sub['is_text'] and sub['codec_raw'] != 'subrip': sub['status'] = 'CONVERT'
                                        else: sub['status'] = 'KEEP'
                                    else: sub['status'] = 'KEEP'
                            else:
                                sub['status'] = 'REMOVE' if sub['status'] != 'REMOVE' else 'KEEP'
                h, _ = stdscr.getmaxyx()
                if my == h - 2: edit_mode = True; curses.curs_set(1)
            except curses.error: pass
            continue

        if edit_mode:
            if key in (10, 13, 27): edit_mode = False; curses.curs_set(0)
            elif key in (curses.KEY_BACKSPACE, 127, 8): output_path = output_path[:-1]
            elif 32 <= key <= 126: output_path += chr(key)
            continue
            
        if move_mode:
            if key == curses.KEY_UP and cursor_pos > 0:
                tracks[cursor_pos], tracks[cursor_pos-1] = tracks[cursor_pos-1], tracks[cursor_pos]
                cursor_pos -= 1
            elif key == curses.KEY_DOWN and cursor_pos < len(tracks) - 1:
                tracks[cursor_pos], tracks[cursor_pos+1] = tracks[cursor_pos+1], tracks[cursor_pos]
                cursor_pos += 1
            elif key in (ord('m'), ord('M'), 27, 10, 13): move_mode = False
            continue

        if key in (ord('q'), ord('Q')): sys.exit(0)
        elif key == curses.KEY_UP: cursor_pos = max(0, cursor_pos - 1)
        elif key == curses.KEY_DOWN: cursor_pos = min(len(tracks)-1, cursor_pos + 1)
        
        elif key == curses.KEY_RIGHT and is_batch:
            if file_idx < total_files - 1: return "__NAV_NEXT__", tracks, output_path, auto_del_ext
            else: curses.flash()
        elif key == curses.KEY_LEFT and is_batch:
            if file_idx > 0: return "__NAV_PREV__", tracks, output_path, auto_del_ext
            else: curses.flash()

        elif key == ord(' '): 
            sub = tracks[cursor_pos]
            if track_type == "Subtitle":
                if sub.get('is_external'):
                    if sub['status'] == 'KEEP': sub['status'] = 'EMBED'
                    elif sub['status'] == 'EMBED': sub['status'] = 'REMOVE'
                    else: sub['status'] = 'KEEP'
                else:
                    sub['status'] = 'REMOVE' if sub['status'] != 'REMOVE' else 'KEEP'
            else:
                sub['status'] = 'REMOVE' if sub['status'] != 'REMOVE' else 'KEEP'
                
        elif key in (ord('d'), ord('D')) and track_type == "Subtitle":
            auto_del_ext = not auto_del_ext
            for s in tracks:
                if s.get('is_external'):
                    if auto_del_ext and s['status'] == 'KEEP':
                        s['status'] = 'EMBED'
                    elif not auto_del_ext and s['status'] == 'EMBED':
                        s['status'] = 'KEEP'
                        
        elif key in (ord('a'), ord('A')): 
            for s in tracks:
                if s['lang'] != 'eng': s['status'] = 'REMOVE'
                
        elif key in (ord('c'), ord('C')) and track_type == "Subtitle": 
            sub = tracks[cursor_pos]
            if sub['status'] == 'CONVERT': sub['status'] = 'KEEP'
            elif sub['is_text'] and sub['codec_raw'] != 'subrip': sub['status'] = 'CONVERT'
            
        elif key in (ord('m'), ord('M')): move_mode = True
        elif key in (ord('o'), ord('O')): edit_mode = True; curses.curs_set(1)
        
        elif key in (ord('r'), ord('R'), 10, 13, curses.KEY_ENTER):
            if has_next_phase:
                return output_path, tracks, 'Y', auto_del_ext
            else:
                conf = draw_confirmation_popup(stdscr, tracks, is_batch, is_batch_identical, track_type)
                if conf in ('Y', 'A'): return output_path, tracks, conf, auto_del_ext
            
    return None

def scan_directory(path, recursive):
    vids = []
    exclude = ('.trickplay', '.bif', 'Backdrops', 'metadata')
    if recursive:
        for root, dirs, files in os.walk(path):
            dirs[:] = [d for d in dirs if d not in exclude]
            for f in files:
                if f.lower().endswith(VIDEO_EXTS): vids.append(os.path.join(root, f))
    else:
        for f in os.listdir(path):
            if f.lower().endswith(VIDEO_EXTS): vids.append(os.path.join(path, f))
    return sorted(vids)

def apply_template_to_file(new_tracks, template_tracks):
    final_tracks = []
    for template_item in template_tracks:
        match = next((s for s in new_tracks if s['original_index'] == template_item['original_index']), None)
        if match:
            match['status'] = template_item['status']
            final_tracks.append(match)
    return final_tracks

def has_file_changed(fpath, out_path, original_subs, new_subs, original_audio=None, new_audio=None):
    if fpath != out_path: return True
    
    if new_audio:
        orig_order = [a['original_index'] for a in original_audio]
        new_order = [a['original_index'] for a in new_audio]
        if orig_order != new_order: return True
        if any(a['status'] == 'REMOVE' for a in new_audio): return True
        
    orig_order = [s['original_index'] for s in original_subs]
    new_order = [s['original_index'] for s in new_subs]
    if orig_order != new_order: return True
        
    for sub in new_subs:
        if sub.get('is_external'):
            if sub['status'] in ('KEEP', 'EMBED'): return True
        else:
            if sub['status'] in ('REMOVE', 'CONVERT'): return True
            
    return False

def main():
    global VERBOSITY
    print_version()

    parser = argparse.ArgumentParser(description="Interactive Media Manager")
    parser.add_argument("path", nargs="?", help="Input file or directory")
    parser.add_argument("-i", "--input", help="Input video file")
    parser.add_argument("-d", "--dir", help="Input directory")
    parser.add_argument("-R", "--recursive", action="store_true", help="Recursive scan")
    parser.add_argument("-A", "--audio", action="store_true", help="Skip subtitle processing and directly configure audio tracks")
    parser.add_argument("-s", "--subs", action="store_true", help="Skip audio prompt and directly configure subtitle tracks")
    parser.add_argument("-v", "--version", action="store_true", help="Show history")
    parser.add_argument("-q", "--quiet", action="store_true", help="Quiet Mode")
    parser.add_argument("-V", "--very-verbose", action="store_true", help="Debug Mode")
    args = parser.parse_args()

    if args.version: print(VERSION_HISTORY); sys.exit(0)

    if args.path and not args.input and not args.dir:
        if os.path.isdir(args.path): args.dir = args.path
        else: args.input = args.path

    if not args.input and not args.dir and not args.path:
        args.dir = "."

    VERBOSITY = 0 if args.quiet else (2 if args.very_verbose else 1)
    
    files_found = []
    if args.input:
        if os.path.exists(args.input): files_found = [args.input]
        else: log(f"Error: File '{args.input}' not found.", 0); sys.exit(1)
    elif args.dir:
        if os.path.exists(args.dir):
            files_found = scan_directory(args.dir, args.recursive)
        else: log(f"Error: Directory '{args.dir}' not found.", 0); sys.exit(1)

    if not files_found:
        print(f"No video files found in '{args.dir}'.")
        if not args.recursive:
            try:
                choice = input(f"Would you like to search recursively in subdirectories of '{args.dir}' for videos? [y/N]: ").strip().lower()
                if choice in ['y', 'yes']:
                    print("Scanning subdirectories recursively...")
                    files_found = scan_directory(args.dir, True)
                    if not files_found:
                        print("Still no video files found after recursive search. Exiting.")
                        sys.exit(0)
                    else:
                        print(f"Found {len(files_found)} video file(s) recursively.\n")
                else:
                    print("Operation cancelled. Exiting.")
                    sys.exit(0)
            except KeyboardInterrupt:
                print("\nOperation cancelled. Exiting.")
                sys.exit(0)
        else:
            print("Exiting.")
            sys.exit(0)

    # Parallel Screening
    files_to_process = []
    preloaded_audio = {}
    preloaded_subs = {}
    is_batch_identical = True
    
    if len(files_found) > 1:
        log(f"Screening {len(files_found)} files for tracks...", 1)
        with ThreadPoolExecutor(max_workers=os.cpu_count()) as executor:
            future_to_file = {executor.submit(init_media_tracks, f): f for f in files_found}
            done_count = 0
            for future in as_completed(future_to_file):
                audio_res, subs_res = future.result()
                f = future_to_file[future]
                if audio_res or subs_res: 
                    files_to_process.append(f)
                    preloaded_audio[f] = audio_res
                    preloaded_subs[f] = subs_res
                done_count += 1
                sys.stdout.write(f"\r  -> Progress: {done_count}/{len(files_found)} screened...")
                sys.stdout.flush()
        files_to_process.sort() 
        log(f"\n  -> Found {len(files_to_process)} actionable files.", 1)
        if not files_to_process: sys.exit(0)
        
        signatures = set()
        for f in files_to_process:
            signatures.add(get_media_signature(preloaded_audio[f], preloaded_subs[f]))
        is_batch_identical = (len(signatures) <= 1)
        if not is_batch_identical:
            log("  -> Note: Batch files have varying media tracks. 'Apply All' will be disabled.", 1)
    else: 
        for f in files_found:
            audio_res, subs_res = init_media_tracks(f)
            if audio_res or subs_res:
                preloaded_audio[f] = audio_res
                preloaded_subs[f] = subs_res
                files_to_process.append(f)
            else:
                log(f"\nWarning: No actionable tracks found for '{os.path.basename(f)}'.", 0)
                
        if not files_to_process:
            sys.exit(0)

    # Batch state and persistence
    apply_all_mode = False
    template_subs_config = []
    template_audio_config = []
    session_subs_persistence = {} 
    session_audio_persistence = {} 
    outpath_persistence = {} 
    audio_decision_cache = {}
    auto_del_ext = False
    execute_batch = False

    # --- TUI Configuration Phase ---
    f_idx = 0
    while f_idx < len(files_to_process):
        fpath = files_to_process[f_idx]
        
        # Determine Audio Processing Requirements
        if fpath not in audio_decision_cache:
            if args.audio:
                audio_decision_cache[fpath] = True
            elif args.subs:
                audio_decision_cache[fpath] = False
            elif len(preloaded_audio[fpath]) > 1:
                print(f"\n--- File: {os.path.basename(fpath)} ---")
                print("Multiple audio tracks detected:")
                for t in preloaded_audio[fpath]:
                    print(f"  Stream #{t['original_index']}: {t['lang']} [{t['codec_raw']}] ({t['channels']} channels)")
                ans = input("Would you like to modify the audio tracks? [y/N]: ").strip().lower()
                audio_decision_cache[fpath] = (ans in ['y', 'yes'])
            else:
                if len(preloaded_audio[fpath]) == 1:
                    print(f"\nOnly 1 audio track found in '{os.path.basename(fpath)}'. Skipping audio configuration.")
                audio_decision_cache[fpath] = False

        do_audio = audio_decision_cache[fpath] and len(preloaded_audio[fpath]) > 0
        do_subs = not args.audio and len(preloaded_subs[fpath]) > 0 
        
        if not do_audio and not do_subs:
            f_idx += 1
            continue

        current_audio = session_audio_persistence.get(fpath, copy.deepcopy(preloaded_audio[fpath]))
        current_subs = session_subs_persistence.get(fpath, copy.deepcopy(preloaded_subs[fpath]))
        current_out = outpath_persistence.get(fpath, fpath)

        navigated = False
        
        if do_audio:
            try:
                res = curses.wrapper(tui_main, args, fpath, current_audio, (len(files_to_process) > 1), f_idx, len(files_to_process), auto_del_ext, is_batch_identical, current_out, "Audio", do_subs)
            except KeyboardInterrupt: log("\nCancelled.", 0); sys.exit(0)
            
            if res and isinstance(res, tuple) and res[0] in ("__NAV_NEXT__", "__NAV_PREV__"):
                session_audio_persistence[fpath] = res[1]
                outpath_persistence[fpath] = res[2]
                f_idx = f_idx + 1 if res[0] == "__NAV_NEXT__" else max(0, f_idx - 1)
                continue
            elif not res:
                f_idx += 1
                continue
            else:
                current_out, current_audio, conf, _ = res
                session_audio_persistence[fpath] = current_audio
                outpath_persistence[fpath] = current_out
                if not do_subs and conf == 'A':
                    apply_all_mode = True
                    template_audio_config = current_audio
                
                if not do_subs:
                    execute_batch = True
                    break

        if do_subs:
            try:
                res = curses.wrapper(tui_main, args, fpath, current_subs, (len(files_to_process) > 1), f_idx, len(files_to_process), auto_del_ext, is_batch_identical, current_out, "Subtitle", False)
            except KeyboardInterrupt: log("\nCancelled.", 0); sys.exit(0)
            
            if res and isinstance(res, tuple) and res[0] in ("__NAV_NEXT__", "__NAV_PREV__"):
                session_subs_persistence[fpath] = res[1]
                outpath_persistence[fpath] = res[2]
                f_idx = f_idx + 1 if res[0] == "__NAV_NEXT__" else max(0, f_idx - 1)
                continue
            elif not res:
                f_idx += 1
                continue
            else:
                current_out, current_subs, conf, auto_del_ext = res
                session_subs_persistence[fpath] = current_subs
                outpath_persistence[fpath] = current_out
                if conf == 'A':
                    apply_all_mode = True
                    template_subs_config = current_subs
                execute_batch = True
                break
            
    if not execute_batch:
        sys.exit(0)
        
    # --- Batch Execution Phase ---
    log("\n==================================================", 1)
    log("            STARTING BATCH EXECUTION              ", 1)
    log("==================================================", 1)

    for i, fpath in enumerate(files_to_process):
        log(f"\n[{i+1}/{len(files_to_process)}] Processing: {os.path.basename(fpath)}", 1)
        
        out_path = outpath_persistence.get(fpath, fpath)
        
        if out_path.lower().endswith('.avi'):
            out_path = out_path[:-4] + '.mkv'
            log("  -> Note: Output container changed to MKV (AVI does not support embedded subs).", 1)
            
        if apply_all_mode:
            if session_audio_persistence.get(fpath) or audio_decision_cache.get(fpath):
                base_audio = copy.deepcopy(preloaded_audio[fpath])
                audio = apply_template_to_file(base_audio, template_audio_config) if template_audio_config else base_audio
            else: audio = copy.deepcopy(preloaded_audio[fpath])
            
            if session_subs_persistence.get(fpath) or not args.audio:
                base_subs = copy.deepcopy(preloaded_subs[fpath])
                subs = apply_template_to_file(base_subs, template_subs_config) if template_subs_config else base_subs
            else: subs = copy.deepcopy(preloaded_subs[fpath])
        else:
            audio = session_audio_persistence.get(fpath, copy.deepcopy(preloaded_audio[fpath]))
            subs = session_subs_persistence.get(fpath, copy.deepcopy(preloaded_subs[fpath]))
            if auto_del_ext: 
                for s in subs:
                    if s.get('is_external') and s['status'] == 'KEEP':
                        s['status'] = 'EMBED'
                        
        if not has_file_changed(fpath, out_path, preloaded_subs[fpath], subs, preloaded_audio[fpath], audio):
            log("  -> Skipped: No changes detected.", 1)
            continue
            
        process_remux(fpath, out_path, subs, audio)

if __name__ == "__main__":
    main()