    'msa': 'Malay', 'may': 'Malay', 'rum': 'Romanian', 'ron': 'Romanian',
    'ukr': 'Ukrainian'
}

SUBTITLE_CODEC_MAP = {
    'subrip': 'SRT',
    'hdmv_pgs_subtitle': 'PGS',
    'dvd_subtitle': 'VobSub',
    'ass': 'ASS',
    'ssa': 'SSA',
