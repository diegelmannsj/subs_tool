    'eng': 'English', 'jpn': 'Japanese', 'und': 'Undetermined',
    'fra': 'French', 'fre': 'French', 'deu': 'German', 'ger': 'German',
    'ita': 'Italian', 'spa': 'Spanish', 'kor': 'Korean',
    'chi': 'Chinese', 'zho': 'Chinese', 'rus': 'Russian',
    'por': 'Portuguese', 'vie': 'Vietnamese', 'tha': 'Thai',
    'swe': 'Swedish', 'nor': 'Norwegian', 'dan': 'Danish',
    'fin': 'Finnish', 'nld': 'Dutch', 'dut': 'Dutch',
    'pol': 'Polish', 'hin': 'Hindi', 'tur': 'Turkish',
    'ara': 'Arabic', 'heb': 'Hebrew', 'cze': 'Czech', 'ces': 'Czech',
    'gre': 'Greek', 'ell': 'Greek', 'hun': 'Hungarian', 'ind': 'Indonesian',
    'msa': 'Malay', 'may': 'Malay', 'rum': 'Romanian', 'ron': 'Romanian',
    'ukr': 'Ukrainian'
}

SUBTITLE_CODEC_MAP = {
    'subrip': 'SRT',
    'hdmv_pgs_subtitle': 'PGS',
    'dvd_subtitle': 'VobSub',
    'ass': 'ASS',
    'ssa': 'SSA',
    'mov_text': 'MovText',
    'webvtt': 'WebVTT',
    'eia_608': 'EIA-608',
    'dvb_subtitle': 'DVB'
}

TEXT_BASED_CODECS = {'ass', 'ssa', 'mov_text', 'webvtt', 'subrip', 'text'}

# --- Core Helper Functions ---

def print_version():
    print(f",subs_tool - Version {VERSION}")
    print("-" * 30)

def format_timestamp(seconds):
    if seconds is None: return "00:00:00,000"
    milliseconds = int((seconds - int(seconds)) * 1000)
    minutes, seconds = divmod(int(seconds), 60)
    hours, minutes = divmod(minutes, 60)
    return f"{hours:02d}:{minutes:02d}:{seconds:02d},{milliseconds:03d}"

def get_stream_info(file_path):
    cmd = ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_streams", file_path]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return json.loads(result.stdout).get('streams', [])
    except Exception:
        return []

def format_track_label(sub_dict):
    """
    Generates a label from a subtitle dictionary (internal structure).
    """
    lang_name = ISO_639_MAP.get(sub_dict['lang'], sub_dict['lang'])
    codec = sub_dict['codec_friendly']
    type_tag = "[TXT]" if sub_dict['is_text'] else "[IMG]"
    title_str = f" - {sub_dict['title']}" if sub_dict['title'] else ""
    
    # Original Index mainly for debugging/reference
    return f"{lang_name} [{sub_dict['lang']}] [{codec}] {type_tag}{title_str}"

# --- OCR Pipeline ---

def extract_subtitle_packets(input_file, stream_index):
    cmd = [
        "ffprobe", "-v", "quiet", 
        "-select_streams", f"{stream_index}",
        "-show_entries", "packet=pts_time,duration_time",
        "-of", "json", input_file
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        packets = json.loads(result.stdout).get("packets", [])
        clean = []
        for p in packets:
            if 'pts_time' in p:
                clean.append({'start': float(p['pts_time']), 'duration': float(p.get('duration_time', 0))})
        return clean
    except Exception: return []

def extract_single_image(input_file, stream_index, timestamp, output_path):
    seek_time = max(0, timestamp + 0.1)
    cmd = [
        "ffmpeg", "-nostdin", "-hide_banner", "-loglevel", "error",
        "-ss", f"{seek_time}", "-i", input_file,
        "-f", "lavfi", "-i", "color=size=1920x1080:color=black:rate=24",
        "-filter_complex", f"[1:v][0:{stream_index}]overlay",
        "-frames:v", "1", "-y", output_path
    ]
    try:
        subprocess.run(cmd, check=True)
        return True
    except subprocess.CalledProcessError: return False

def perform_manual_ocr(input_file, stream_index, lang_code, codec_friendly, output_srt, temp_dir):
    print(f"    ... Processing Stream #{stream_index} ({lang_code}) [{codec_friendly}] via OCR...")
    stream_temp_dir = os.path.join(temp_dir, f"stream_{stream_index}")
    if os.path.exists(stream_temp_dir): shutil.rmtree(stream_temp_dir)
    os.makedirs(stream_temp_dir, exist_ok=True)

    packets = extract_subtitle_packets(input_file, stream_index)
    if not packets: return False, "No packets found."

    print(f"    -> Rendering {len(packets)} images (Multithreaded)...")
    with ThreadPoolExecutor(max_workers=4) as executor:
        for i, packet in enumerate(packets):
            img = os.path.join(stream_temp_dir, f"img_{i:05d}.tif")
            executor.submit(extract_single_image, input_file, stream_index, packet['start'], img)
    
    images = sorted(glob.glob(os.path.join(stream_temp_dir, "*.tif")))
    if not images: return False, "No images extracted."
    
    count = min(len(images), len(packets))
    print(f"    -> OCRing {count} lines...")
    srt_lines = []
    if lang_code == 'und': lang_code = 'eng'
    
    for i in range(count):
        if count > 10 and i % (count // 10) == 0:
            sys.stdout.write("."); sys.stdout.flush()
        try:
            res = subprocess.run(["tesseract", images[i], "stdout", "-l", lang_code, "--psm", "6"], capture_output=True, text=True)
            text = res.stdout.strip()
            if text:
                start = format_timestamp(packets[i]['start'])
                end = format_timestamp(packets[i]['start'] + max(packets[i]['duration'], 1.5))
                srt_lines.append(f"{i+1}\n{start} --> {end}\n{text}\n")
        except Exception: pass
    
    sys.stdout.write("\n")
    if not srt_lines: return False, "No text recognized."
        
    with open(output_srt, 'w', encoding='utf-8') as f: f.write("\n".join(srt_lines))
    shutil.rmtree(stream_temp_dir)
    return True, "Success"

def perform_text_conversion(input_file, stream_index, output_srt):
    print(f"    ... Converting Stream #{stream_index} (Text-Based) -> SRT...")
    cmd = ["ffmpeg", "-nostdin", "-hide_banner", "-loglevel", "error", "-i", input_file, "-map", f"0:{stream_index}", "-c:s", "srt", "-y", output_srt]
    try:
        subprocess.run(cmd, check=True)
        return True
    except subprocess.CalledProcessError as e:
        print(f"    -> Conversion Failed: {e}")
        return False

# --- Main Processing Logic ---

def process_remux(input_path, output_path, subs_list):
    """
    subs_list: List of dicts representing the FINAL desired order.
    Each dict has: { 'original_index': int, 'status': 'KEEP'/'REMOVE'/'CONVERT', ... }
    """
    os.makedirs(TEMP_DIR, exist_ok=True)
    base_name = os.path.basename(output_path)
    temp_final = os.path.join(TEMP_DIR, f"TEMP_REMUX_{int(time.time())}_{base_name}")
    ocr_work_dir = os.path.join(TEMP_DIR, "OCR_WORK")
    os.makedirs(ocr_work_dir, exist_ok=True)

    all_streams = get_stream_info(input_path)
    converted_inputs = {} # Map original_index -> {path, lang, title}

    # 1. Conversion Phase
    subs_to_convert = [s for s in subs_list if s['status'] == 'CONVERT']
    
    if subs_to_convert:
        print("\n--- Starting Conversion Phase ---")
        has_image_subs = any(not s['is_text'] for s in subs_to_convert)
        if has_image_subs and not shutil.which("tesseract"):
            print("Error: Tesseract not installed. Cannot convert image-based subs.")
            return

        for sub in subs_to_convert:
            idx = sub['original_index']
            srt_path = os.path.join(ocr_work_dir, f"converted_{idx}.srt")
            success = False
            
            if sub['is_text']:
                success = perform_text_conversion(input_path, idx, srt_path)
            else:
                success, reason = perform_manual_ocr(input_path, idx, sub['lang'], sub['codec_friendly'], srt_path, ocr_work_dir)
                if not success:
                    print(f"Warning: OCR Failed for Stream #{idx}. Reason: {reason}")
                    try:
                        choice = input(f"    How do you want to handle this track? [K]eep Original or [R]emove? [K/r]: ").lower().strip()
                        if choice == 'r':
                            print(f"    -> Marking Stream #{idx} for REMOVAL.")
                            sub['status'] = 'REMOVE'
                        else:
                            print(f"    -> Keeping Stream #{idx} as original.")
                            sub['status'] = 'KEEP'
                    except KeyboardInterrupt:
                        print("\nCancelled."); return

            if success:
                converted_inputs[idx] = {
                    'path': srt_path,
                    'lang': sub['lang'],
                    'title': f"{sub['title']} (OCR)" if sub['title'] else "OCR"
                }

    # 2. Build FFmpeg Command
    print("\n--- Building Final File ---")
    cmd = ["ffmpeg", "-hide_banner", "-v", "error", "-stats", "-i", input_path]
    
    # Add SRT inputs. Store mapping: original_idx -> ffmpeg input index (1, 2, 3...)
    # We load them in order of original index to keep things tidy
    sorted_conv_indices = sorted(converted_inputs.keys())
    input_file_map = {}
    for i, idx in enumerate(sorted_conv_indices):
        cmd.extend(["-i", converted_inputs[idx]['path']])
        input_file_map[idx] = i + 1

    # Map Video & Audio (All, preserving original order)
    for s in all_streams:
        if s.get('codec_type') == 'video': cmd.extend(["-map", f"0:{s['index']}"])
    for s in all_streams:
        if s.get('codec_type') == 'audio': cmd.extend(["-map", f"0:{s['index']}"])
            
    # Map Subtitles (User-Defined Order)
    # We iterate through 'subs_list', which is already re-ordered by the user
    current_out_idx = 0
    
    for sub in subs_list:
        status = sub['status']
        orig_idx = sub['original_index']
        
        if status == 'REMOVE':
            continue
            
        elif status == 'KEEP':
            cmd.extend(["-map", f"0:{orig_idx}"])
            current_out_idx += 1
            
        elif status == 'CONVERT':
            if orig_idx in converted_inputs:
                # Map from the new SRT input
                input_idx = input_file_map[orig_idx]
                cmd.extend(["-map", f"{input_idx}:0"])
                
                # Apply Metadata
                meta = converted_inputs[orig_idx]
                cmd.extend([
                    f"-metadata:s:s:{current_out_idx}", f"language={meta['lang']}",
                    f"-metadata:s:s:{current_out_idx}", f"title={meta['title']}"
                ])
                current_out_idx += 1
            else:
                # Fallback if conversion marked success but not in map (shouldn't happen)
                cmd.extend(["-map", f"0:{orig_idx}"])
                current_out_idx += 1

    # Map Attachments/Data
    cmd.extend(["-map", "0:d?", "-map", "0:t?"])
    cmd.extend(["-c", "copy", "-map_metadata", "0", "-y", temp_final])
    
    try:
        subprocess.run(cmd, check=True)
        if os.path.exists(temp_final) and os.path.getsize(temp_final) > 0:
            print(f"Moving to: {output_path}")
            shutil.move(temp_final, output_path)
            print("Success!")
        else: print("Error: Output empty.")
    except subprocess.CalledProcessError as e: print(f"FFmpeg Error: {e}")
    finally:
        if os.path.exists(ocr_work_dir): shutil.rmtree(ocr_work_dir)

# --- TUI Functions ---

def draw_menu(stdscr, filename, subtitles, output_path, cursor_pos, edit_mode, move_mode):
    stdscr.clear()
    h, w = stdscr.getmaxyx()
    
    # Header
    header = f",subs_tool v{VERSION} - {filename}"
    stdscr.addstr(0, 0, header[:w-1], curses.A_BOLD | curses.A_UNDERLINE)
    
    # Instructions line
    if move_mode:
        instr = "[UP/DOWN] Move Track | [M] Exit Move Mode"
        color = curses.color_pair(4) # Yellow/Warning color for move mode
    else:
        instr = "[Space] Toggle | [M] Move | [A] No-Eng | [C] Convert | [R] Run | [Q] Quit"
        color = curses.A_DIM
        
    stdscr.addstr(1, 0, instr[:w-1], color)
    stdscr.addstr(2, 0, "-" * (w-1))

    # List
    list_start_y = 3
    max_visible = h - 6
    scroll_offset = max(0, cursor_pos - max_visible + 1)
    
    for i in range(max_visible):
        idx_in_list = i + scroll_offset
        if idx_in_list >= len(subtitles): break
        
        sub = subtitles[idx_in_list]
        label = format_track_label(sub)
        status = sub['status']
        
        # Style
        color = curses.color_pair(2) # Green KEEP
        check = "[ ] KEEP   "
        if status == 'REMOVE':
            color = curses.color_pair(1) # Red
            check = "[*] REMOVE "
        elif status == 'CONVERT':
            color = curses.color_pair(3) # Cyan
            check = "[C] CONVERT"
            
        style = color
        
        # Highlight Logic
        if idx_in_list == cursor_pos and not edit_mode:
            if move_mode:
                style = curses.color_pair(4) | curses.A_BOLD # Yellow for moving item
                check = " < MOVE >  "
            else:
                style |= curses.A_REVERSE
            
        line = f" {check} {label}"
        stdscr.addstr(list_start_y + i, 0, line[:w-1], style)

    # Output
    out_y = h - 2
    lbl = "Output: "
    stdscr.addstr(out_y, 0, lbl, curses.A_BOLD)
    style_path = curses.A_REVERSE if edit_mode else curses.A_NORMAL
    disp_path = output_path
    avail = w - len(lbl) - 1
    if len(disp_path) > avail: disp_path = "..." + disp_path[-(avail-3):]
    stdscr.addstr(out_y, len(lbl), disp_path, style_path)
    stdscr.refresh()

def draw_confirmation_popup(stdscr, subtitles):
    """Draws a detailed scrollable confirmation list."""
    h, w = stdscr.getmaxyx()
    box_h, box_w = h - 4, w - 8
    start_y, start_x = 2, 4
    
    win = curses.newwin(box_h, box_w, start_y, start_x)
    win.keypad(True)
    win.box()
    
    win.addstr(1, 2, "FINAL TRACK LIST PREVIEW", curses.A_BOLD | curses.A_UNDERLINE)
    win.addstr(box_h-2, 2, "Press [Y]es to Proceed, [N]o/Esc to Cancel, [Up/Down] Scroll")
    
    # Filter final list (exclude removed)
    final_list = [s for s in subtitles if s['status'] != 'REMOVE']
    
    scroll_pos = 0
    max_lines = box_h - 4
    
    while True:
        # Draw Content
        for i in range(max_lines):
            idx = i + scroll_pos
            if idx >= len(final_list):
                # Clear empty lines
                win.addstr(2+i, 2, " " * (box_w - 4))
                continue
                
            sub = final_list[idx]
            # Format: 1. English [SRT] (Converted)
            prefix = f"{idx+1}. "
            
            lang_name = ISO_639_MAP.get(sub['lang'], sub['lang'])
            codec = sub['codec_friendly']
            note = ""
            
            attr = curses.color_pair(2) # Green
            if sub['status'] == 'CONVERT':
                codec = "SRT"
                note = " (Converted)"
                attr = curses.color_pair(3) # Cyan
                
            line = f"{prefix}{lang_name} [{codec}]{note}"
            win.addstr(2+i, 2, line[:box_w-4].ljust(box_w-4), attr)
            
        win.refresh()
        
        key = win.getch()
        if key in (ord('y'), ord('Y'), 10, 13): return True
        if key in (ord('n'), ord('N'), 27): return False
        
        if key == curses.KEY_DOWN:
            if scroll_pos < len(final_list) - max_lines: scroll_pos += 1
        elif key == curses.KEY_UP:
            if scroll_pos > 0: scroll_pos -= 1

def draw_prompt_popup(stdscr, title, prompt):
    h, w = stdscr.getmaxyx()
    box_h, box_w = 8, 60
    start_y, start_x = (h - box_h) // 2, (w - box_w) // 2
    win = curses.newwin(box_h, box_w, start_y, start_x)
    win.box()
    win.addstr(1, 2, title[:box_w-4], curses.A_BOLD)
    win.addstr(3, 4, prompt[:box_w-6])
    win.addstr(5, 4, "[Y]es / [N]o")
    win.refresh()
    while True:
        key = stdscr.getch()
        if key in (ord('y'), ord('Y')): return True
        if key in (ord('n'), ord('N'), 27): return False

def tui_main(stdscr, args):
    curses.start_color()
    curses.use_default_colors()
    curses.init_pair(1, curses.COLOR_RED, -1)    # Remove
    curses.init_pair(2, curses.COLOR_GREEN, -1)  # Keep
    curses.init_pair(3, curses.COLOR_CYAN, -1)   # Convert
    curses.init_pair(4, curses.COLOR_YELLOW, -1) # Moving
    
    curses.curs_set(0)
    stdscr.timeout(100)
    
    input_path = os.path.abspath(args.input)
    filename = os.path.basename(input_path)
    output_path = input_path
    
    raw_streams = get_stream_info(input_path)
    raw_subs = [s for s in raw_streams if s.get('codec_type') == 'subtitle']
    if not raw_subs: return None
    
    # Initialize Internal List Structure
    subtitles = []
    for s in raw_subs:
        codec_raw = s.get('codec_name', 'unknown')
        subtitles.append({
            'original_index': s['index'],
            'lang': s.get('tags', {}).get('language', 'und'),
            'title': s.get('tags', {}).get('title', ''),
            'codec_raw': codec_raw,
            'codec_friendly': SUBTITLE_CODEC_MAP.get(codec_raw, codec_raw),
            'is_text': codec_raw in TEXT_BASED_CODECS,
            'status': 'KEEP'
        })
    
    cursor_pos = 0
    edit_mode = False
    move_mode = False
    
    while True:
        draw_menu(stdscr, filename, subtitles, output_path, cursor_pos, edit_mode, move_mode)
        key = stdscr.getch()
        
        if edit_mode:
            if key in (10, 13, 27): 
                edit_mode = False; curses.curs_set(0)
            elif key in (curses.KEY_BACKSPACE, 127, 8): output_path = output_path[:-1]
            elif 32 <= key <= 126: output_path += chr(key)
            continue
            
        if move_mode:
            if key == curses.KEY_UP:
                if cursor_pos > 0:
                    # Swap
                    subtitles[cursor_pos], subtitles[cursor_pos-1] = subtitles[cursor_pos-1], subtitles[cursor_pos]
                    cursor_pos -= 1
            elif key == curses.KEY_DOWN:
                if cursor_pos < len(subtitles) - 1:
                    subtitles[cursor_pos], subtitles[cursor_pos+1] = subtitles[cursor_pos+1], subtitles[cursor_pos]
                    cursor_pos += 1
            elif key in (ord('m'), ord('M'), 27, 10, 13):
                move_mode = False
            continue

        # Normal Mode
        if key in (ord('q'), ord('Q')): sys.exit(0)
        elif key == curses.KEY_UP: cursor_pos = max(0, cursor_pos - 1)
        elif key == curses.KEY_DOWN: cursor_pos = min(len(subtitles)-1, cursor_pos + 1)
        
        elif key == ord(' '): # Toggle
            curr = subtitles[cursor_pos]['status']
            if curr == 'KEEP': subtitles[cursor_pos]['status'] = 'REMOVE'
            elif curr == 'REMOVE': subtitles[cursor_pos]['status'] = 'KEEP'
            elif curr == 'CONVERT': subtitles[cursor_pos]['status'] = 'REMOVE'
            
        elif key in (ord('a'), ord('A')): # Remove Non-Eng
            for s in subtitles:
                if s['lang'] != 'eng': s['status'] = 'REMOVE'
                
        elif key in (ord('c'), ord('C')): # Convert
            include_text = False
            has_text = any(s['is_text'] for s in subtitles)
            if has_text:
                if draw_prompt_popup(stdscr, "Convert Options", "Include text-based subs?"):
                    include_text = True
            
            for s in subtitles:
                if not s['is_text']: s['status'] = 'CONVERT'
                elif include_text and s['codec_raw'] != 'subrip': s['status'] = 'CONVERT'
        
        elif key in (ord('m'), ord('M')): move_mode = True
        elif key in (ord('o'), ord('O')): edit_mode = True; curses.curs_set(1)
        
        elif key in (ord('r'), ord('R')):
            if draw_confirmation_popup(stdscr, subtitles):
                break

    return output_path, subtitles

def main():
    parser = argparse.ArgumentParser(description="Interactive Subtitle Tool")
    parser.add_argument("-i", "--input", help="Input video file")
    parser.add_argument("-v", "--version", action="store_true", help="Show history")
    args = parser.parse_args()

    print_version()
    if args.version: print(VERSION_HISTORY); sys.exit(0)
    if not args.input or not os.path.exists(args.input):
        print("Error: Input file required."); sys.exit(1)

    streams = get_stream_info(args.input)
    if not any(s.get('codec_type') == 'subtitle' for s in streams):
        print("No subtitle tracks found."); sys.exit(0)

    try:
        result = curses.wrapper(tui_main, args)
    except KeyboardInterrupt: print("\nCancelled."); sys.exit(0)
        
    if not result: sys.exit(0)
    out_path, subs_list = result
    
    actions = [s for s in subs_list if s['status'] in ('REMOVE', 'CONVERT')]
    # Check if reorder happened (indices out of sync)
    reordered = False
    for i, s in enumerate(subs_list):
        if i != sorted(subs_list, key=lambda x: x['original_index']).index(s):
            reordered = True; break
            
    if not actions and not reordered:
        print("No changes selected."); sys.exit(0)
        
    process_remux(args.input, out_path, subs_list)

if __name__ == "__main__":
    main()
