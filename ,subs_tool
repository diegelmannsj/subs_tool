#!/usr/bin/env python3
"""
,subs_rm - Interactive Subtitle Remover

A TUI tool to manually select and remove specific subtitle tracks from a video file.
Uses ffmpeg for lossless remuxing.

Author: Buzzy's Admin
Target System: Fedora Linux (buzzy)
"""

import curses
import argparse
import subprocess
import json
import sys
import os
import shutil
import time

# --- Configuration ---
TEMP_DIR = "/storage/temp/"
VERSION = "1.3.0"

# ISO-639 Mapping (Shared with ,hvec)
ISO_639_MAP = {
    'eng': 'English', 'jpn': 'Japanese', 'und': 'Undetermined',
    'fra': 'French', 'fre': 'French', 'deu': 'German', 'ger': 'German',
    'ita': 'Italian', 'spa': 'Spanish', 'kor': 'Korean',
    'chi': 'Chinese', 'zho': 'Chinese', 'rus': 'Russian',
    'por': 'Portuguese', 'vie': 'Vietnamese', 'tha': 'Thai',
    'swe': 'Swedish', 'nor': 'Norwegian', 'dan': 'Danish',
    'fin': 'Finnish', 'nld': 'Dutch', 'dut': 'Dutch',
    'pol': 'Polish', 'hin': 'Hindi', 'tur': 'Turkish',
    'ara': 'Arabic', 'heb': 'Hebrew', 'cze': 'Czech', 'ces': 'Czech',
    'gre': 'Greek', 'ell': 'Greek', 'hun': 'Hungarian', 'ind': 'Indonesian',
    'msa': 'Malay', 'may': 'Malay', 'rum': 'Romanian', 'ron': 'Romanian',
    'ukr': 'Ukrainian'
}

SUBTITLE_CODEC_MAP = {
    'subrip': 'SRT',
    'hdmv_pgs_subtitle': 'PGS',
    'dvd_subtitle': 'VobSub',
    'ass': 'ASS',
    'ssa': 'SSA',
    'mov_text': 'MovText',
    'webvtt': 'WebVTT',
    'eia_608': 'EIA-608',
    'dvb_subtitle': 'DVB'
}

def get_stream_info(file_path):
    """Uses ffprobe to get JSON output of stream data."""
    cmd = [
        "ffprobe", "-v", "quiet", "-print_format", "json", "-show_streams", file_path
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return json.loads(result.stdout).get('streams', [])
    except Exception:
        return []

def format_subtitle_label(stream):
    """Creates a human-readable label for a subtitle stream."""
    idx = stream.get('index')
    codec_raw = stream.get('codec_name', 'unknown')
    codec_friendly = SUBTITLE_CODEC_MAP.get(codec_raw, codec_raw)

    tags = stream.get('tags', {})
    lang_code = tags.get('language', 'und')
    lang_name = ISO_639_MAP.get(lang_code, lang_code)

    title = tags.get('title', '')
    title_str = f" - {title}" if title else ""

    return f"Stream #{idx}: {lang_name} [{lang_code}] [{codec_friendly}]{title_str}"

def remux_file(input_path, output_path, subs_to_remove_indices):
    """
    Performs the ffmpeg remux operation.
    Maps all streams explicitly to ensure exact preservation of audio/video.
    """
    # Ensure temp dir exists
    os.makedirs(TEMP_DIR, exist_ok=True)

    # Generate temp filename
    base_name = os.path.basename(output_path)
    temp_file = os.path.join(TEMP_DIR, f"TEMP_REMUX_{int(time.time())}_{base_name}")

    all_streams = get_stream_info(input_path)
    cmd = ["ffmpeg", "-hide_banner", "-v", "error", "-stats", "-i", input_path]

    # Explicitly map streams instead of using wildcards to guarantee order and preservation
    # Map Video
    for s in all_streams:
        if s.get('codec_type') == 'video':
            cmd.extend(["-map", f"0:{s['index']}"])

    # Map Audio
    for s in all_streams:
        if s.get('codec_type') == 'audio':
            cmd.extend(["-map", f"0:{s['index']}"])

    # Map Subtitles (Conditionally)
    kept_count = 0
    for s in all_streams:
        if s.get('codec_type') == 'subtitle':
            idx = s['index']
            if idx not in subs_to_remove_indices:
                cmd.extend(["-map", f"0:{idx}"])
                kept_count += 1

    # Map Attachments/Data
    cmd.extend(["-map", "0:d?", "-map", "0:t?"])

    # Force COPY for everything to ensure no transcoding happens
    cmd.extend(["-c", "copy", "-map_metadata", "0", "-y", temp_file])

    print(f"\n--- Processing Remux ---")

    try:
        subprocess.run(cmd, check=True)

        # Verify output exists
        if os.path.exists(temp_file) and os.path.getsize(temp_file) > 0:
            print(f"Moving file to final destination...")
            shutil.move(temp_file, output_path)
            print(f"Success! Saved to: {output_path}")
            return True
        else:
            print("\nError: Output file is empty or missing.")
            return False

    except subprocess.CalledProcessError as e:
        print(f"\nFFmpeg Error: {e}")
        if os.path.exists(temp_file):
            os.remove(temp_file)
        return False

# --- UI Functions (Curses) ---

def draw_menu(stdscr, filename, subtitles, selected_indices, output_path, cursor_pos, edit_mode=False):
    stdscr.clear()
    h, w = stdscr.getmaxyx()

    # Header / Directions
    header_1 = f",subs_rm v{VERSION} - {filename}"
    header_2 = "Directions: [Space] Toggle to REMOVE | [Q] Quit | [O] Output Path | [R] Remux"

    # Draw Headers
    stdscr.addstr(0, 0, header_1[:w-1], curses.A_BOLD | curses.A_UNDERLINE)
    stdscr.addstr(1, 0, header_2[:w-1], curses.A_DIM)

    # Separator
    stdscr.addstr(2, 0, "-" * (w-1))

    # Subtitle List
    list_start_y = 3
    # Dynamic sizing logic: Ensure we don't draw off-screen
    max_visible_items = h - 6

    # Simple scrolling window logic (keep cursor centered if possible)
    scroll_offset = 0
    if cursor_pos >= max_visible_items:
        scroll_offset = cursor_pos - max_visible_items + 1

    for i in range(max_visible_items):
        idx_in_list = i + scroll_offset
        if idx_in_list >= len(subtitles): break

        sub = subtitles[idx_in_list]
        idx = sub['index']
        label = format_subtitle_label(sub)

        # Determine Status
        is_selected_for_removal = idx in selected_indices
        check = "[*] REMOVE" if is_selected_for_removal else "[ ] KEEP  "

        # Determine Color
        # Default to normal, override with Red/Green if supported
        color_attr = curses.A_NORMAL
        if curses.has_colors():
            if is_selected_for_removal:
                color_attr = curses.color_pair(1) # Red
            else:
                color_attr = curses.color_pair(2) # Green

        # Determine Highlight (Cursor)
        style = color_attr
        if idx_in_list == cursor_pos and not edit_mode:
            style |= curses.A_REVERSE

        # Formatting
        line = f" {check} {label}"
        stdscr.addstr(list_start_y + i, 0, line[:w-1], style)

    # Output Path Section (Bottom)
    out_y = h - 2
    path_label = "Output Path: "
    stdscr.addstr(out_y, 0, path_label, curses.A_BOLD)

    path_style = curses.A_REVERSE if edit_mode else curses.A_NORMAL
    # Ensure path fits
    avail_w = w - len(path_label) - 1
    display_path = output_path
    if len(output_path) > avail_w:
        display_path = "..." + output_path[-(avail_w-3):]

    stdscr.addstr(out_y, len(path_label), display_path, path_style)

    stdscr.refresh()

def tui_main(stdscr, args):
    # Setup Colors
    curses.start_color()
    curses.use_default_colors()
    # Pair 1: Red text (for removal)
    curses.init_pair(1, curses.COLOR_RED, -1)
    # Pair 2: Green text (for keep)
    curses.init_pair(2, curses.COLOR_GREEN, -1)

    # Setup Settings
    curses.curs_set(0) # Hide cursor
    stdscr.timeout(100)

    input_path = os.path.abspath(args.input)
    filename = os.path.basename(input_path)
    output_path = input_path # Default overwrite

    # Load Streams
    streams = get_stream_info(input_path)
    subtitles = [s for s in streams if s.get('codec_type') == 'subtitle']

    if not subtitles:
        return None

    # State
    cursor_pos = 0
    selected_indices = set() # Set of stream indices to REMOVE
    edit_mode = False

    while True:
        draw_menu(stdscr, filename, subtitles, selected_indices, output_path, cursor_pos, edit_mode)

        key = stdscr.getch()

        if edit_mode:
            # Handle Text Entry for Output Path
            if key in (10, 13): # Enter
                edit_mode = False
                curses.curs_set(0)
            elif key == 27: # Esc
                edit_mode = False
                curses.curs_set(0)
            elif key in (curses.KEY_BACKSPACE, 127, 8):
                output_path = output_path[:-1]
            elif 32 <= key <= 126: # Printable chars
                output_path += chr(key)
            continue

        # Normal Navigation Mode
        if key == ord('q') or key == ord('Q'):
            sys.exit(0)

        elif key == curses.KEY_UP:
            cursor_pos = max(0, cursor_pos - 1)

        elif key == curses.KEY_DOWN:
            cursor_pos = min(len(subtitles) - 1, cursor_pos + 1)

        elif key == ord(' '): # Spacebar Toggle
            current_idx = subtitles[cursor_pos]['index']
            if current_idx in selected_indices:
                selected_indices.remove(current_idx)
            else:
                selected_indices.add(current_idx)

        elif key == ord('o') or key == ord('O'):
            edit_mode = True
            curses.curs_set(1) # Show cursor

        elif key == ord('r') or key == ord('R'):
            # Exit loop to start processing
            break

    # Exit Curses context before processing
    return output_path, selected_indices

def confirm_plan(input_path, output_path, selected_indices):
    """Prints a plain text summary and asks for confirmation."""
    print("\n" + "="*40)
    print("       SUBTITLE REMOVAL PLAN")
    print("="*40)
    print(f"Input:  {os.path.basename(input_path)}")
    print(f"Output: {output_path}")
    print("-" * 40)

    streams = get_stream_info(input_path)
    subtitles = [s for s in streams if s.get('codec_type') == 'subtitle']

    print("ACTIONS:")
    for sub in subtitles:
        idx = sub['index']
        label = format_subtitle_label(sub)
        if idx in selected_indices:
            print(f"  [X] REMOVE: {label}")
        else:
            print(f"  [ ] KEEP:   {label}")

    print("-" * 40)

    try:
        ans = input("Proceed with these changes? [y/N]: ").lower().strip()
        return ans == 'y'
    except KeyboardInterrupt:
        return False

def main():
    parser = argparse.ArgumentParser(description="Interactive Subtitle Remover")
    parser.add_argument("-i", "--input", required=True, help="Input video file")
    args = parser.parse_args()

    if not os.path.exists(args.input):
        print(f"Error: File not found: {args.input}")
        sys.exit(1)

    # Check for subtitles first to avoid clearing screen unnecessarily
    streams = get_stream_info(args.input)
    subs = [s for s in streams if s.get('codec_type') == 'subtitle']
    if not subs:
        print("No subtitle tracks found in this file.")
        sys.exit(0)

    # Run TUI wrapper
    try:
        result = curses.wrapper(tui_main, args)
    except KeyboardInterrupt:
        print("\nCancelled.")
        sys.exit(0)

    if not result:
        sys.exit(0)

    final_output, subs_to_remove = result

    # Confirmation Step (Outside Curses)
    if not confirm_plan(args.input, final_output, subs_to_remove):
        print("\nOperation cancelled.")
        sys.exit(0)

    if not subs_to_remove:
        print("No subtitle tracks selected for removal. Exiting.")
        sys.exit(0)

    # Run the heavy lifting
    remux_file(args.input, final_output, subs_to_remove)

if __name__ == "__main__":
    main()
