def format_timestamp(seconds):
    if seconds is None: return "00:00:00,000"
    milliseconds = int((seconds - int(seconds)) * 1000)
    minutes, seconds = divmod(int(seconds), 60)
    hours, minutes = divmod(minutes, 60)
    return f"{hours:02d}:{minutes:02d}:{seconds:02d},{milliseconds:03d}"

def get_stream_info(file_path):
    cmd = ["ffprobe", "-v", "quiet", "-print_format", "json", "-show_streams", file_path]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        return json.loads(result.stdout).get('streams', [])
    except Exception:
        return []

def get_track_structure_signature(file_path):
    """
    Generates a unique signature string for the subtitle structure of a file.
    Format: "count|index:codec:lang|index:codec:lang..."
    Used to verify if 'Apply to All' is safe.
    """
    streams = get_stream_info(file_path)
    subs = [s for s in streams if s.get('codec_type') == 'subtitle']
    if not subs: return "NONE"
    
    sig_parts = [str(len(subs))]
    for s in subs:
        idx = s['index']
        codec = s.get('codec_name', 'unk')
        lang = s.get('tags', {}).get('language', 'und')
        sig_parts.append(f"{idx}:{codec}:{lang}")
    
    return "|".join(sig_parts)

def format_track_label(sub_dict):
    lang_name = ISO_639_MAP.get(sub_dict['lang'], sub_dict['lang'])
    codec = sub_dict['codec_friendly']
    type_tag = "[TXT]" if sub_dict['is_text'] else "[IMG]"
    title_str = f" - {sub_dict['title']}" if sub_dict['title'] else ""
    return f"{lang_name} [{sub_dict['lang']}] [{codec}] {type_tag}{title_str}"

# --- OCR Pipeline ---

def extract_subtitle_packets(input_file, stream_index):
    cmd = [
        "ffprobe", "-v", "quiet", 
        "-select_streams", f"{stream_index}",
        "-show_entries", "packet=pts_time,duration_time",
        "-of", "json", input_file
    ]
    try:
        result = subprocess.run(cmd, capture_output=True, text=True, check=True)
        packets = json.loads(result.stdout).get("packets", [])
        clean = []
        for p in packets:
            if 'pts_time' in p:
                clean.append({'start': float(p['pts_time']), 'duration': float(p.get('duration_time', 0))})
        return clean
    except Exception: return []

def extract_single_image(input_file, stream_index, timestamp, output_path):
    seek_time = max(0, timestamp + 0.1)
    cmd = [
        "ffmpeg", "-nostdin", "-hide_banner", "-loglevel", "error",
        "-ss", f"{seek_time}", "-i", input_file,
        "-f", "lavfi", "-i", "color=size=1920x1080:color=black:rate=24",
        "-filter_complex", f"[1:v][0:{stream_index}]overlay",
        "-frames:v", "1", "-y", output_path
    ]
    try:
        subprocess.run(cmd, check=True)
        return True
    except subprocess.CalledProcessError: return False

def perform_manual_ocr(input_file, stream_index, lang_code, codec_friendly, output_srt, temp_dir):
    print(f"    ... Processing Stream #{stream_index} ({lang_code}) [{codec_friendly}] via OCR...")
    stream_temp_dir = os.path.join(temp_dir, f"stream_{stream_index}")
    if os.path.exists(stream_temp_dir): shutil.rmtree(stream_temp_dir)
    os.makedirs(stream_temp_dir, exist_ok=True)

    packets = extract_subtitle_packets(input_file, stream_index)
    if not packets: return False, "No packets found."

    print(f"    -> Rendering {len(packets)} images (Multithreaded)...")
    with ThreadPoolExecutor(max_workers=4) as executor:
        for i, packet in enumerate(packets):
            img = os.path.join(stream_temp_dir, f"img_{i:05d}.tif")
            executor.submit(extract_single_image, input_file, stream_index, packet['start'], img)
    
    images = sorted(glob.glob(os.path.join(stream_temp_dir, "*.tif")))
    if not images: return False, "No images extracted."
    
    count = min(len(images), len(packets))
    print(f"    -> OCRing {count} lines...")
    srt_lines = []
    if lang_code == 'und': lang_code = 'eng'
    
    for i in range(count):
        if count > 10 and i % (count // 10) == 0:
            sys.stdout.write("."); sys.stdout.flush()
        try:
            res = subprocess.run(["tesseract", images[i], "stdout", "-l", lang_code, "--psm", "6"], capture_output=True, text=True)
            text = res.stdout.strip()
            if text:
                start = format_timestamp(packets[i]['start'])
                end = format_timestamp(packets[i]['start'] + max(packets[i]['duration'], 1.5))
                srt_lines.append(f"{i+1}\n{start} --> {end}\n{text}\n")
        except Exception: pass
    
    sys.stdout.write("\n")
    if not srt_lines: return False, "No text recognized."
        
    with open(output_srt, 'w', encoding='utf-8') as f: f.write("\n".join(srt_lines))
    shutil.rmtree(stream_temp_dir)
    return True, "Success"

def perform_text_conversion(input_file, stream_index, output_srt):
    print(f"    ... Converting Stream #{stream_index} (Text-Based) -> SRT...")
    cmd = ["ffmpeg", "-nostdin", "-hide_banner", "-loglevel", "error", "-i", input_file, "-map", f"0:{stream_index}", "-c:s", "srt", "-y", output_srt]
    try:
        subprocess.run(cmd, check=True)
        return True
    except subprocess.CalledProcessError as e:
        print(f"    -> Conversion Failed: {e}")
        return False

# --- Main Processing Logic ---

def smart_move_file(source, destination):
    """
    Moves file using 'pv' for progress if on different filesystems,
    otherwise uses atomic rename.
    """
    try:
        # Check filesystems
        src_dev = os.stat(source).st_dev
        dest_dir = os.path.dirname(os.path.abspath(destination))
        if not os.path.exists(dest_dir): os.makedirs(dest_dir)
        dest_dev = os.stat(dest_dir).st_dev
        
        # If different devices and pv exists, pipe it
        if src_dev != dest_dev and shutil.which('pv'):
            print(f"Moving to: {destination} (via pv)...")
            size = os.path.getsize(source)
            cmd = f"pv \"{source}\" -s {size} > \"{destination}\""
            subprocess.run(cmd, shell=True, check=True)
            os.remove(source)
            return True
        else:
            # Same device OR no pv -> Standard Move
            print(f"Moving to: {destination}...")
            shutil.move(source, destination)
            return True
    except Exception as e:
        print(f"Error moving file: {e}")
        return False

def process_remux(input_path, output_path, subs_list):
    """
    subs_list: List of dicts representing the FINAL desired order.
    Each dict has: { 'original_index': int, 'status': 'KEEP'/'REMOVE'/'CONVERT', ... }
    """
    os.makedirs(TEMP_DIR, exist_ok=True)
    base_name = os.path.basename(output_path)
    temp_final = os.path.join(TEMP_DIR, f"TEMP_REMUX_{int(time.time())}_{base_name}")
    ocr_work_dir = os.path.join(TEMP_DIR, "OCR_WORK")
    os.makedirs(ocr_work_dir, exist_ok=True)

    all_streams = get_stream_info(input_path)
    converted_inputs = {} # Map original_index -> {path, lang, title}

    # 1. Conversion Phase
    subs_to_convert = [s for s in subs_list if s['status'] == 'CONVERT']
    
    if subs_to_convert:
        print("\n--- Starting Conversion Phase ---")
        has_image_subs = any(not s['is_text'] for s in subs_to_convert)
        if has_image_subs and not shutil.which("tesseract"):
            print("Error: Tesseract not installed. Cannot convert image-based subs.")
            return

        for sub in subs_to_convert:
            idx = sub['original_index']
            srt_path = os.path.join(ocr_work_dir, f"converted_{idx}.srt")
            success = False
            
            if sub['is_text']:
                success = perform_text_conversion(input_path, idx, srt_path)
            else:
                success, reason = perform_manual_ocr(input_path, idx, sub['lang'], sub['codec_friendly'], srt_path, ocr_work_dir)
                if not success:
                    print(f"Warning: OCR Failed for Stream #{idx}. Reason: {reason}")
                    try:
                        choice = input(f"    How do you want to handle this track? [K]eep Original or [R]emove? [K/r]: ").lower().strip()
                        if choice == 'r':
                            print(f"    -> Marking Stream #{idx} for REMOVAL.")
                            sub['status'] = 'REMOVE'
                        else:
                            print(f"    -> Keeping Stream #{idx} as original.")
                            sub['status'] = 'KEEP'
                    except KeyboardInterrupt:
                        print("\nCancelled."); return

            if success:
                converted_inputs[idx] = {
                    'path': srt_path,
                    'lang': sub['lang'],
                    'title': f"{sub['title']} (OCR)" if sub['title'] else "OCR"
                }

    # 2. Build FFmpeg Command
    print("\n--- Building Final File ---")
    cmd = ["ffmpeg", "-hide_banner", "-v", "error", "-stats", "-i", input_path]
    
    sorted_conv_indices = sorted(converted_inputs.keys())
    input_file_map = {}
    for i, idx in enumerate(sorted_conv_indices):
        cmd.extend(["-i", converted_inputs[idx]['path']])
        input_file_map[idx] = i + 1

    # Map Video & Audio
    for s in all_streams:
        if s.get('codec_type') == 'video': cmd.extend(["-map", f"0:{s['index']}"])
    for s in all_streams:
        if s.get('codec_type') == 'audio': cmd.extend(["-map", f"0:{s['index']}"])
            
    # Map Subtitles
    current_out_idx = 0
    for sub in subs_list:
        status = sub['status']
        orig_idx = sub['original_index']
        
        if status == 'REMOVE': continue
            
        elif status == 'KEEP':
            cmd.extend(["-map", f"0:{orig_idx}"])
            current_out_idx += 1
            
        elif status == 'CONVERT':
            if orig_idx in converted_inputs:
                input_idx = input_file_map[orig_idx]
                cmd.extend(["-map", f"{input_idx}:0"])
                meta = converted_inputs[orig_idx]
                cmd.extend([
                    f"-metadata:s:s:{current_out_idx}", f"language={meta['lang']}",
                    f"-metadata:s:s:{current_out_idx}", f"title={meta['title']}"
                ])
                current_out_idx += 1
            else:
                # Fallback
                cmd.extend(["-map", f"0:{orig_idx}"])
                current_out_idx += 1

    # Map Attachments/Data
    cmd.extend(["-map", "0:d?", "-map", "0:t?"])
    cmd.extend(["-c", "copy", "-map_metadata", "0", "-y", temp_final])
    
    try:
        subprocess.run(cmd, check=True)
        if os.path.exists(temp_final) and os.path.getsize(temp_final) > 0:
            if smart_move_file(temp_final, output_path):
                print("Success!")
        else: print("Error: Output empty.")
    except subprocess.CalledProcessError as e: print(f"FFmpeg Error: {e}")
    finally:
        if os.path.exists(ocr_work_dir): shutil.rmtree(ocr_work_dir)

